{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-radius: {{ section.settings.image_radius }}px;
    
    {%- if section.settings.use_custom_colors %}
      --color-background: {{ section.settings.colors_background }};
      --color-foreground: {{ section.settings.colors_text }};
      --color-heading: {{ section.settings.colors_text }};
    {% endif -%}
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top_mob }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }

  {%- if section.settings.use_custom_colors %}
    #shopify-section-{{ section.id }} .image-slider-wrapper {
      background-color: var(--color-background);
      color: var(--color-foreground);
    }
    #shopify-section-{{ section.id }} .title,
    #shopify-section-{{ section.id }} .subheading,
    #shopify-section-{{ section.id }} .description {
      color: var(--color-foreground);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .image-slider-layout {
    display: flex;
    flex-direction: column-reverse;
    gap: 2rem;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .image-slider-layout {
      flex-direction: row;
      align-items: center;
      gap: 5rem;
    }
  }

  #shopify-section-{{ section.id }} .image-slider__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .image-slider__info {
      flex: 0 0 48rem;
    }
  }

  #shopify-section-{{ section.id }} .subheading {
    margin: 0;
    font-family: var(--new-font-body-family);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .title {
    margin: 0;
    font-family: var(--new-font-heading-family);
  }
  #shopify-section-{{ section.id }} .title.h0 {
    font-size: 5.2rem;
  }
  #shopify-section-{{ section.id }} .title.h1 {
    font-size: 4.2rem;
  }
  #shopify-section-{{ section.id }} .description {
    margin: 0;
    font-family: var(--new-font-body-family);
    font-size: 1.6rem;
    line-height: 1.4;
    letter-spacing: 0;
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .image-slider__track {
    width: 100%;
    min-width: 0; 
  }
  
  #shopify-section-{{ section.id }} .swiper {
    width: 100%;
    border-radius: var(--image-radius);
    overflow: visible;
    clip-path: inset(-100vw -100vw -100vw 0);
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .swiper {
      clip-path: none;
      overflow: visible; /* Allows native overflow bleeding on mobile */
    }
  }

  .is-card {
    position: relative;
    border-radius: var(--image-radius);
    overflow: hidden;
    display: block;
    width: 100%;
    text-decoration: none;
  }
  .is-card__image-wrapper {
    position: relative;
    width: 100%;
  }
  .is-card__image-wrapper--portrait { padding-bottom: 150%; }
  .is-card__image-wrapper--square { padding-bottom: 100%; }
  .is-card__image-wrapper--landscape { padding-bottom: 75%; }
  .is-card__image-wrapper--adapt { padding-bottom: var(--image-ratio); }
  .is-card__image {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  /* Only apply hover scale if it's an actual link */
  a.is-card:hover .is-card__image {
    transform: scale(1.03);
  }
  
  .is-card__overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    z-index: 2;
    transition: background 0.4s ease;
  }
  a.is-card:hover .is-card__overlay {
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 | plus: 0.1 }});
  }
  .is-card__title {
    color: {{ section.settings.overlay_text_color }};
    margin: 0;
    font-family: var(--new-font-heading-family);
    font-size: 2.8rem;
    font-weight: 400;
    line-height: 1.2;
    text-align: center;
    z-index: 3;
    transition: transform 0.2s ease;
  }
  a.is-card:hover .is-card__title {
    transform: scale(1.01);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .image-slider-wrapper {
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .image-slider__info {
      gap: 1.2rem;
    }
    #shopify-section-{{ section.id }} .subheading {
      font-size: 1.2rem;
    }
    #shopify-section-{{ section.id }} .title.h0 {
      font-size: 3rem;
    }
    #shopify-section-{{ section.id }} .title.h1 {
      font-size: 2.6rem;
    }
    #shopify-section-{{ section.id }} .description {
      font-size: 1.4rem;
    }
    .is-card__image-wrapper--portrait { padding-bottom: 125%; }
    .is-card__title {
      font-size: 2rem;
    }
  }
{%- endstyle -%}

<div class="image-slider-wrapper section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width">
    
    <div class="image-slider-layout">
      
      <div class="image-slider__info">
        {%- if section.settings.subheading != blank -%}
          <div class="subheading">{{ section.settings.subheading }}</div>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>

      <div class="image-slider__track">
        <div class="swiper image-swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            
            {%- for block in section.blocks -%}
              {%- liquid
                assign final_image = block.settings.image
                assign final_title = block.settings.title | newline_to_br
                
                assign ratio = 100
                if section.settings.image_ratio == 'adapt' and final_image != blank
                  assign ratio = 1 | divided_by: final_image.aspect_ratio | times: 100
                endif
              -%}

              <div class="swiper-slide" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="is-card">
                {%- else -%}
                  <div class="is-card">
                {%- endif -%}

                  <div class="is-card__image-wrapper is-card__image-wrapper--{{ section.settings.image_ratio }}" style="--image-ratio: {{ ratio }}%;">
                    {%- if final_image != blank -%}
                      {{ final_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'is-card__image' }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg is-card__image' }}
                    {%- endif -%}
                  </div>
                  
                  {%- if final_title != blank -%}
                    <div class="is-card__overlay">
                      <h3 class="is-card__title">{{ final_title }}</h3>
                    </div>
                  {%- endif -%}
                  
                {%- if block.settings.link != blank -%}
                  </a>
                {%- else -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
            
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.image-swiper-{{ section.id }}', {
      slidesPerView: 1.5,
      spaceBetween: 10,
      breakpoints: {
        768: {
          slidesPerView: 2.2
        },
        1024: {
          slidesPerView: 2,
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Image Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Gallery"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Our Journey in Pictures",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>A visual look at the people, places, and processes behind our brand.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p", "label": "Paragraph" }
      ],
      "default": "h2",
      "label": "Heading SEO Tag"
    },
    {
      "type": "header",
      "content": "Card Styling"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "portrait",
      "label": "Image Ratio"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Dark Overlay Opacity",
      "default": 30
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Overlay Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Background Colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "default": false,
      "label": "Use Custom Colors"
    },
    {
      "type": "color",
      "id": "colors_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "colors_text",
      "label": "Text",
      "default": "#212326"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": false,
      "label": "Show Top/Bottom Divider"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Overlay Title",
          "info": "Leave blank if you just want to show the image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide Link",
          "info": "Optional link if clicked."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Slider",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}