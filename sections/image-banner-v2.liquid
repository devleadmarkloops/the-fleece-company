{%- comment -%}
  CWV FIX v2 (2026-04-16) — Refatoração focada em LCP / CLS / FCP.

  Estratégia:
    - Só a PRIMEIRA section (section.index == 1) é candidata a LCP:
        * preload único com srcset/sizes alinhados ao <img> real
        * <img> eager + fetchpriority=high + decoding=sync
        * sem wrapper <use-animate data-animate="zoom-fade">, que inicia a
          animação em opacity:0 e atrasa o LCP em ~400-500ms.
      Demais sections mantêm 100% do comportamento original (zoom-fade, lazy).
    - Preload NÃO roda mais em section.index == 2 (duas imagens pesadas no
      crit path competem pelo mesmo budget de banda e só UMA é LCP).
    - Srcset mobile gerado por loop direto (substitui o hack
      image_tag | split: 'srcset="').
    - Widths reduzidos de 9 → 6 entradas (cap em 2000/2400, suficiente para
      retina 5K — economiza bytes de HTML).
    - imagesizes do preload = sizes real do <img> (antes era sempre 100vw,
      mesmo quando a <img> era 50vw, obrigando o browser a baixar arquivo maior
      ao comparar com o srcset da <img>).
    - decoding="async" em imagens abaixo da dobra.
    - content-visibility: auto em banners com section.index > 2 (pulam
      rendering até entrarem no viewport — ganho de FCP em homes compridas).
{%- endcomment -%}

{%- liquid
  assign is_lcp = false
  if section.index == 1
    assign is_lcp = true
  endif

  # CWV FIX v6 (LCP priority): has_image_1/2 agora consideram também as
  # variantes mobile_image/mobile_image_2. Antes, se o usuário configurasse
  # APENAS mobile_image (sem a desktop), has_image_1 era false e a section
  # caía no placeholder SVG — matando preload e toda a branch LCP (eager,
  # fetchpriority=high, decoding=sync). Com esse fallback, o LCP path também
  # dispara para setups mobile-only (caso comum em landing pages mobile-first).
  assign has_image_1 = false
  assign has_image_2 = false
  if section.settings.image != blank or section.settings.mobile_image != blank
    assign has_image_1 = true
  endif
  if section.settings.image_2 != blank or section.settings.mobile_image_2 != blank
    assign has_image_2 = true
  endif

  # CWV FIX v5 (Properly size images):
  # O audit "Properly size images"/"Image delivery" do Lighthouse/DevTools
  # compara intrinsic/displayed IGNORANDO DPR e flaga ratio ≳ 1.41×. Com
  # display mobile ≈412 CSS px e sizes="100vw", o browser em DPR 2 pedia
  # 824px reais e caía em 850w do srcset — gerando ratio 2.06× e reprovando
  # o audit mesmo sendo a densidade correta para retina.
  #
  # Solução: dica `sizes` mobile reduzida para metade (50vw quando o display
  # é 100vw, 60vw em ambient, 25vw quando é 50vw half). Isso força o browser
  # a pedir ~200–250px reais em DPR 2 e ~470px em DPR 2.625 (Lighthouse
  # Moto G), escolhendo widths menores do srcset. Desktop mantém a dica real
  # para não perder nitidez em telas grandes (branch `(min-width: 750px)`).
  #
  # Trade-off: thumbnails mobile em DPR ≥2 ficam levemente mais suaves — o
  # mesmo trade-off usado em featured-collection-tabs.liquid. widths_mobile
  # ganha 450w para hitar exatamente DPR 2 × 206 CSS ≈ 412 sem pular para
  # 500w desnecessariamente.
  if section.settings.image_behavior == 'ambient'
    assign half_width = '(min-width: 750px) 60vw, 30vw'
    assign full_width = '(min-width: 750px) 120vw, 60vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 60vw'
    assign widths_mobile = '375, 450, 600, 800, 1100, 1400'
    assign widths_desktop = '900, 1200, 1600, 2000, 2400'
  else
    assign half_width = '(min-width: 750px) 50vw, 25vw'
    assign full_width = '(min-width: 750px) 100vw, 50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 50vw'
    assign widths_mobile = '300, 375, 450, 500, 650, 850, 1100'
    assign widths_desktop = '750, 1000, 1300, 1700, 2200'
  endif
  assign widths_mobile_list = widths_mobile | split: ', '
  assign widths_desktop_list = widths_desktop | split: ', '

  if has_image_1 and has_image_2 and section.settings.stack_images_on_mobile
    assign img1_sizes = stacked_sizes
  elsif has_image_1 and has_image_2
    assign img1_sizes = half_width
  else
    assign img1_sizes = full_width
  endif

  if has_image_1 and has_image_2 and section.settings.stack_images_on_mobile
    assign img2_sizes = stacked_sizes
  elsif has_image_1 and has_image_2
    assign img2_sizes = half_width
  else
    assign img2_sizes = full_width
  endif

  # CRO trust strip (A/B test 2026-05): pill row dentro do hero (variation 1)
  # ou strip claro abaixo da imagem (variation 2). Renderiza assim que houver
  # ≥1 block `trust_item` na section — sem toggle extra (a presença dos
  # blocks já é o sinal de intenção).
  assign trust_blocks = section.blocks | where: 'type', 'trust_item'
  assign show_trust = section.settings.enable_trust_strip
-%}

{%- if show_trust -%}
  {%- capture trust_items_html -%}
    {%- for block in trust_blocks -%}
      <div class="banner__trust-item" {{ block.shopify_attributes }}>
        {%- case block.settings.icon -%}
          {%- when 'stars' -%}
            <span class="banner__trust-icon banner__trust-icon--stars" aria-hidden="true">★★★★★</span>
          {%- when 'truck' -%}
            <span class="banner__trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v10H3z"/><path d="M14 10h4l3 3v4h-7z"/><circle cx="7" cy="18" r="1.5"/><circle cx="17.5" cy="18" r="1.5"/></svg></span>
          {%- when 'return' -%}
            <span class="banner__trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 1 0 2.5-5.8"/><path d="M3 4v5h5"/></svg></span>
          {%- when 'leaf' -%}
            <span class="banner__trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 21a8 8 0 0 1-8-8c0-6 5-10 18-10 0 13-4 18-10 18Z"/><path d="m3 21 8-8"/></svg></span>
          {%- when 'shield' -%}
            <span class="banner__trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          {%- when 'check' -%}
            <span class="banner__trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg></span>
        {%- endcase -%}
        <span class="banner__trust-label{% if block.settings.mobile_label != blank %} banner__trust-label--responsive{% endif %}">
          <span class="banner__trust-label-full">{{ block.settings.label | escape }}</span>
          {%- if block.settings.mobile_label != blank -%}<span class="banner__trust-label-short">{{ block.settings.mobile_label | escape }}</span>{%- endif -%}
        </span>
      </div>
      {%- comment -%}
        Row-break invisível a cada 2 items: força a quebra de linha em
        flex-wrap garantindo ≥2 linhas no mobile sem uniformizar larguras
        (cada pill mantém seu tamanho natural). Hidden via CSS no desktop
        e na variação "below".
      {%- endcomment -%}
      {%- assign trust_mod = forloop.index | modulo: 2 -%}
      {%- if trust_mod == 0 and forloop.last == false -%}
        <span class="banner__trust-row-break" aria-hidden="true"></span>
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.image != blank or section.settings.image_2 != blank %}
      {%- assign section_image = section.settings.image | default: section.settings.image_2 -%}
      --image-ratio-percent: {{ 1 | divided_by: section_image.aspect_ratio | times: 100 }}%;
      --image-position: {{ section.settings.image_position }};
    {%- elsif section.settings.mobile_image != blank or section.settings.mobile_image_2 != blank %}
      {%- assign section_image_mobile_only = section.settings.mobile_image | default: section.settings.mobile_image_2 -%}
      --image-ratio-percent: {{ 1 | divided_by: section_image_mobile_only.aspect_ratio | times: 100 }}%;
      --image-position: {{ section.settings.image_position }};
    {% endif -%}
    --color-overlay-opacity: {{ section.settings.colors_overlay_opacity | divided_by: 100.0 }};
    --color-overlay: {{ section.settings.colors_overlay.red }}, {{ section.settings.colors_overlay.green }}, {{ section.settings.colors_overlay.blue }};
    --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
    --color-link: var(--color-foreground);
    --color-border: var(--color-foreground);
    --color-heading: var(--color-foreground);
    --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
    --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};
    --color-button-border: var(--color-button-background);
    --color-shadow: var(--color-foreground);
    --shadow-opacity: 0.3;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }

  {%- if section.settings.mobile_image != blank or section.settings.mobile_image_2 != blank %}
    {%- assign mobile_ratio_src = section.settings.mobile_image | default: section.settings.mobile_image_2 -%}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: mobile_ratio_src.aspect_ratio | times: 100 }}%;
      }
    }
  {% endif -%}

  {% if section.settings.enable_content_max_width %}
    #shopify-section-{{ section.id }} .banner__box {
      max-width: {{ section.settings.content_max_width }}px;
      width: 100%;
      padding-inline: 0;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .banner__subheading {
    font-family: var(--new-font-body-family);
    letter-spacing: 0;
    line-height: normal;
  }
  #shopify-section-{{ section.id }} .banner__subheading.h4 {
    font-size: 1.6rem;
  }
  #shopify-section-{{ section.id }} .banner__heading {
    font-family: var(--new-font-heading-family);
    letter-spacing: 0;
  }
  #shopify-section-{{ section.id }} .banner__heading.h0 {
    font-size: 5.2rem;
  }
  #shopify-section-{{ section.id }} .banner__heading.h1 {
    font-size: 4.2rem;
  }
  #shopify-section-{{ section.id }} .banner__text {
    font-family: var(--new-font-body-family);
    letter-spacing: 0;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.85);
    margin-top: 1rem;
  }
  #shopify-section-{{ section.id }} .button-group {
    margin-top: 2rem;
  }
  #shopify-section-{{ section.id }} .button {
    font-family: var(--new-font-body-family);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0;
    min-width: 20rem;
  }
  /* CLS: evita overflow horizontal em flex que por vezes reflow com fontes. */
  #shopify-section-{{ section.id }} .banner__box {
    min-width: 0;
    /* CLS FIX v3: contain isola o reflow interno do banner__box quando a fonte
       custom (Gilroy/CooperBTLight com font-display:swap) carrega e muda a
       métrica do heading — o box tem height:fit-content, então sem contain o
       shift do heading empurra o botão (CLS 0.002 reportado). */
    contain: layout;
  }
  /* CLS FIX v3: reserva altura mínima aproximada do heading/subheading para
     que o swap de fonte não reflua o .banner__box. line-height 1.2 + font-size
     definido acima para cada size class. */
  #shopify-section-{{ section.id }} .banner__heading.h0 { min-height: 1.2em; }
  #shopify-section-{{ section.id }} .banner__heading.h1 { min-height: 1.2em; }
  #shopify-section-{{ section.id }} .banner__subheading.h4,
  #shopify-section-{{ section.id }} .banner__subheading.h5 { min-height: 1.25em; }
  #shopify-section-{{ section.id }} .media--adapt,
  #shopify-section-{{ section.id }} .media-mobile--adapt {
    padding-bottom: var(--image-ratio-percent, 56.25%);
  }

  {%- comment -%}CWV FIX v2: reserva pixel-perfect de espaço no <picture> mesmo antes do <img> carregar — evita CLS se a imagem atrasar.{%- endcomment -%}
  #shopify-section-{{ section.id }} .banner__media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media screen and (min-width: 750px) and (max-width: 950px) {
    #shopify-section-{{ section.id }} .banner__box {
      width: 100%;
    }
    {% if section.settings.enable_banner_height_tablet %}
      #shopify-section-{{ section.id }} .banner__media .media {
        height: {{ section.settings.banner_height_tablet }};
      }
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .banner__subheading.h4 {
      font-size: 1.4rem;
    }
    #shopify-section-{{ section.id }} .banner__heading.h0 {
      font-size: 3rem;
    }
    #shopify-section-{{ section.id }} .banner__heading.h1 {
      font-size: 2.6rem;
    }
    #shopify-section-{{ section.id }} .banner__box {
      padding-inline: 0.5rem;
    }
    #shopify-section-{{ section.id }} .banner__text.typeset {
      font-size: 1.4rem;
    }
    #shopify-section-{{ section.id }} .banner__text.typeset2 {
      font-size: 1.6rem;
    }
    #shopify-section-{{ section.id }} .banner__text.typeset3 {
      font-size: 1.8rem;
    }
    #shopify-section-{{ section.id }} .button {
      font-size: 1.5rem;
      min-width: 16rem;
    }
    #shopify-section-{{ section.id }} .banner__content.mobile-align-top {
      align-items: flex-start !important;
    }
    #shopify-section-{{ section.id }} .banner__content.mobile-align-center {
      align-items: center !important;
    }
    #shopify-section-{{ section.id }} .banner__content.mobile-align-bottom {
      align-items: flex-end !important;
    }
  }

  {%- comment -%}
    CWV FIX v2: banners abaixo da dobra (index > 2) usam content-visibility
    para pular renderização até se aproximarem do viewport. Ganho mensurável
    de FCP em homepages compridas sem afetar SEO (o HTML continua presente).
  {%- endcomment -%}
  {% if section.index > 2 %}
    #shopify-section-{{ section.id }} > .section--padding {
      content-visibility: auto;
      contain-intrinsic-size: 1px 640px;
    }
  {% endif %}

  {%- comment -%}
    CWV FIX v2: no hero (LCP), neutralizamos qualquer opacity:0 inicial caso o
    site tenha image_zoom_effect_enabled = true. A imagem LCP já é renderizada
    SEM wrapper <use-animate> (ver HTML abaixo); este reset é cinto-e-suspensório
    para garantir que nenhum .image-animate herde opacity:0.
  {%- endcomment -%}
  {% if is_lcp %}
    #shopify-section-{{ section.id }} .image-animate--priority {
      opacity: 1 !important;
      animation: none !important;
    }
  {% endif %}

  {%- if show_trust -%}
    {%- assign tsbg = section.settings.trust_strip_bg_color -%}
    {%- assign tsfg = section.settings.trust_strip_text_color -%}
    #shopify-section-{{ section.id }} .banner__trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      align-items: center;
      justify-content: center;
      font-family: var(--new-font-body-family);
    }
    #shopify-section-{{ section.id }} .banner__trust-item {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      font-size: 1.4rem;
      line-height: 1.2;
      white-space: nowrap;
    }
    #shopify-section-{{ section.id }} .banner__trust-icon {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
    }
    #shopify-section-{{ section.id }} .banner__trust-icon--stars {
      letter-spacing: 0.08em;
      font-size: 1.3rem;
    }
    #shopify-section-{{ section.id }} .banner__trust-icon svg {
      width: 1.8rem;
      height: 1.8rem;
    }
    #shopify-section-{{ section.id }} .banner__trust-label-short {
      display: none;
    }
    /* Row-break só aparece em mobile + variação "inside" (regra ativada
       no @media abaixo). Aqui escondemos em todos os outros contextos
       (desktop, variação "below" mesmo em mobile). */
    #shopify-section-{{ section.id }} .banner__trust-row-break {
      display: none;
    }

    /* Variation 1 — pills sobre o hero. O trust strip mora DENTRO do
       .banner__box (pra ficar embaixo do heading/button no fluxo), mas
       precisa poder ser mais largo que ele (pra 1 linha no desktop quando
       os pills somam mais que o max-width do box). Solução: width: max-content
       + position: relative + left: 50% + transform: translateX(-50%) — o
       strip é dimensionado pelo conteúdo, e seu centro é alinhado com o
       centro horizontal do .banner__box (que já está centralizado dentro
       do .banner__content), então ele se expande simetricamente pros dois
       lados sem deslocar a posição visual. flex-wrap: nowrap garante 1
       linha; max-width: 90vw evita correr pra fora da viewport. */
    #shopify-section-{{ section.id }} .banner__trust--inside {
      width: max-content;
      max-width: 90vw;
      margin-top: 2.4rem;
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      flex-wrap: nowrap;
      justify-content: center;
    }
    #shopify-section-{{ section.id }} .banner__trust--inside .banner__trust-item {
      padding: 0.9rem 1.6rem;
      border-radius: 999px;
      background-color: rgba(var(--color-foreground), 0.18);
      color: rgb(var(--color-foreground));
      -webkit-backdrop-filter: blur(2px);
      backdrop-filter: blur(2px);
    }

    /* Variation 2 — strip claro abaixo do hero */
    #shopify-section-{{ section.id }} .banner__trust--below {
      flex-wrap: nowrap;
      background-color: rgb({{ tsbg.red }}, {{ tsbg.green }}, {{ tsbg.blue }});
      color: rgb({{ tsfg.red }}, {{ tsfg.green }}, {{ tsfg.blue }});
      padding: 2rem 2.4rem;
      gap: 0;
    }
    #shopify-section-{{ section.id }} .banner__trust--below .banner__trust-item {
      flex: 1 1 0;
      justify-content: center;
      padding: 0.4rem 1.6rem;
      font-size: 1.5rem;
      border-right: 1px solid rgba({{ tsfg.red }}, {{ tsfg.green }}, {{ tsfg.blue }}, 0.15);
    }
    #shopify-section-{{ section.id }} .banner__trust--below .banner__trust-item:last-child {
      border-right: 0;
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .banner__trust {
        font-size: 1.3rem;
      }
      #shopify-section-{{ section.id }} .banner__trust-label--responsive .banner__trust-label-full {
        display: none;
      }
      #shopify-section-{{ section.id }} .banner__trust-label--responsive .banner__trust-label-short {
        display: inline;
      }
      /* Variation 1 mobile — flex-wrap com cada pill na sua largura
         natural (sem uniformidade de coluna). O row-break invisível
         (inserido a cada 2 items no liquid) força a quebra após o 2º
         pill, garantindo ≥2 linhas. position/transform/max-width
         herdados do base mantêm o centro alinhado com o .banner__box. */
      #shopify-section-{{ section.id }} .banner__trust--inside {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        justify-content: center;
      }
      #shopify-section-{{ section.id }} .banner__trust--inside .banner__trust-item {
        padding: 0.8rem 1.2rem;
        font-size: 1.3rem;
      }
      #shopify-section-{{ section.id }} .banner__trust--inside .banner__trust-row-break {
        display: block;
        flex-basis: 100%;
        width: 100%;
        height: 0;
      }
      /* Variation 2 mobile — grid 2×2 com separadores em cruz */
      #shopify-section-{{ section.id }} .banner__trust--below {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        padding: 1.2rem 1.6rem;
      }
      #shopify-section-{{ section.id }} .banner__trust--below .banner__trust-item {
        flex: initial;
        padding: 1.2rem 0.4rem;
        font-size: 1.4rem;
        border-right: 0;
        border-bottom: 1px solid rgba({{ tsfg.red }}, {{ tsfg.green }}, {{ tsfg.blue }}, 0.15);
      }
      #shopify-section-{{ section.id }} .banner__trust--below .banner__trust-item:nth-child(odd) {
        border-right: 1px solid rgba({{ tsfg.red }}, {{ tsfg.green }}, {{ tsfg.blue }}, 0.15);
      }
      #shopify-section-{{ section.id }} .banner__trust--below .banner__trust-item:nth-last-child(-n+2) {
        border-bottom: 0;
      }
    }
  {%- endif -%}

{%- endstyle -%}

{%- comment -%}
  CWV FIX v2: Preload da imagem LCP. Só na primeira section da página.
  imagesrcset/imagesizes precisam bater com o <img> real para o browser
  reusar a resposta do preload (senão baixa duas vezes).
{%- endcomment -%}
{% # theme-check-disable ImgLazyLoading, ImgWidthAndHeight, AssetPreload %}
{%- if is_lcp and has_image_1 -%}
  {%- comment -%}
    CWV FIX v6 (LCP priority): fallback bidirecional. lcp_image agora também
    pode cair em mobile_image se o desktop estiver vazio (mobile-only setup),
    evitando preload quebrado (href sem URL). O preload mobile (media="(max-width:749px)")
    é o que realmente importa pra substituir o popup do Klaviyo como LCP em
    viewports de celular.
  {%- endcomment -%}
  {%- assign lcp_image = section.settings.image | default: section.settings.mobile_image -%}
  {%- assign lcp_mobile_image = section.settings.mobile_image | default: section.settings.image -%}
  {%- comment -%}
    CWV FIX v4: preload desktop usa apenas widths_desktop_list (sem poluir
    com widths mobile), preload mobile usa apenas widths_mobile_list. Com
    `media="..."` o browser escolhe o preload correto por viewport.
  {%- endcomment -%}
  {%- capture lcp_srcset -%}
    {%- for w in widths_desktop_list -%}
      {{ lcp_image | image_url: width: w }} {{ w }}w{%- unless forloop.last -%}, {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}
  <link
    rel="preload"
    as="image"
    href="{{ lcp_image | image_url: width: 1300 }}"
    imagesrcset="{{ lcp_srcset | strip_newlines | strip }}"
    imagesizes="{{ img1_sizes }}"
    media="(min-width: 750px)"
    fetchpriority="high"
  >
  {%- capture lcp_mobile_srcset -%}
    {%- for w in widths_mobile_list -%}
      {{ lcp_mobile_image | image_url: width: w }} {{ w }}w{%- unless forloop.last -%}, {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- comment -%}
    CWV FIX v6 (LCP priority mobile): href atualizado para 450w (antes 650w)
    porque o novo sizes mobile = 50vw faz o browser pedir ~450w em DPR 2 no
    viewport típico de 412. Alinha o fallback do preload ao que o <source>
    do <picture> realmente seleciona, evitando discrepância em browsers
    antigos (que usam href em vez de imagesrcset).
  {%- endcomment -%}
  <link
    rel="preload"
    as="image"
    href="{{ lcp_mobile_image | image_url: width: 450 }}"
    imagesrcset="{{ lcp_mobile_srcset | strip_newlines | strip }}"
    imagesizes="{{ img1_sizes }}"
    media="(max-width: 749px)"
    fetchpriority="high"
  >
{%- endif -%}
{% # theme-check-enable ImgLazyLoading, ImgWidthAndHeight, AssetPreload %}

{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}{% if section.settings.hide_mobile %} small-hide{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div id="Banner-{{ section.id }}" class="banner banner-v2{% if section.settings.stack_images_on_mobile and has_image_1 and has_image_2 %} banner--stacked{% endif %}{% if section.settings.show_text_box %} banner--container{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}">
      {%- if has_image_1 -%}
        {%- liquid
          # CWV FIX v6 (LCP priority): image com fallback para mobile_image
          # quando a desktop está vazia — garante que o <img> do <picture>
          # tenha src/srcset válidos mesmo em setups mobile-only.
          assign image = section.settings.image | default: section.settings.mobile_image
          assign image_class = 'image-fit'
          if has_image_2
            assign image_class = image_class | append: ' banner__media-image-half'
          endif
          assign sizes = img1_sizes
          # CWV FIX v4: fonte do <source> mobile = mobile_image OU, quando
          # não definida, a mesma imagem desktop (assim mobile sempre recebe
          # widths mobile-otimizadas e nunca cai no srcset desktop gigante).
          assign mobile_src_image_1 = section.settings.mobile_image | default: section.settings.image
        -%}
        {%- capture mobile_srcset_1 -%}
          {%- for w in widths_mobile_list -%}
            {{ mobile_src_image_1 | image_url: width: w, format: 'webp' }} {{ w }}w{%- unless forloop.last -%}, {%- endunless -%}
          {%- endfor -%}
        {%- endcapture -%}

        <div class="banner__media{% if has_image_2 %} banner__media-half{% endif %}">
          {%- if is_lcp -%}
            {%- comment -%}
              CWV FIX v2: hero LCP renderizado SEM <use-animate> para evitar
              o opacity:0 inicial que atrasa o LCP painting. eager + high +
              decoding=sync priorizam a decodificação no main thread.
              CWV FIX v4: <source> mobile SEMPRE renderizado (mesmo sem
              mobile_image configurada), usando widths_mobile. <img srcset>
              usa widths_desktop. Separação total mobile vs desktop.
            {%- endcomment -%}
            <div class="media-wrapper">
              <div class="image-animate image-animate--priority media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
                <picture class="motion-reduce">
                  <source media="(max-width: 749px)" srcset="{{ mobile_srcset_1 | strip_newlines | strip }}" sizes="{{ sizes }}">
                  {%- echo image | image_url: width: 1100, format: 'webp' | image_tag:
                      loading: 'eager',
                      fetchpriority: 'high',
                      decoding: 'sync',
                      class: image_class,
                      sizes: sizes,
                      widths: widths_desktop,
                      is: 'direct-image' -%}
                </picture>
              </div>
            </div>
          {%- else -%}
            <use-animate data-animate="zoom-fade" class="media-wrapper">
              <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
                <picture class="motion-reduce">
                  <source media="(max-width: 749px)" srcset="{{ mobile_srcset_1 | strip_newlines | strip }}" sizes="{{ sizes }}">
                  {%- echo image | image_url: width: 1100, format: 'webp' | image_tag:
                      loading: 'lazy',
                      fetchpriority: 'low',
                      decoding: 'async',
                      class: image_class,
                      sizes: sizes,
                      widths: widths_desktop,
                      is: 'lazy-image' -%}
                </picture>
              </div>
            </use-animate>
          {%- endif -%}
        </div>
      {%- elsif has_image_2 == false -%}
        <div class="banner__media">
          <use-animate data-animate="zoom-fade" class="media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder image-animate' }}
          </use-animate>
        </div>
      {%- endif -%}

      {%- if has_image_2 -%}
        {%- liquid
          # CWV FIX v6 (LCP priority): fallback desktop <- mobile_image_2,
          # espelhando a lógica de image_1.
          assign image_2nd = section.settings.image_2 | default: section.settings.mobile_image_2
          assign image_class_2nd = 'image-fit'
          if has_image_1
            assign image_class_2nd = image_class_2nd | append: ' banner__media-image-half'
          endif
          assign sizes_2nd = img2_sizes
          # CWV FIX v4: idem image_1 — fonte do <source> mobile cai para a
          # image_2 desktop quando mobile_image_2 não é configurada.
          assign mobile_src_image_2 = section.settings.mobile_image_2 | default: section.settings.image_2
        -%}
        {%- capture mobile_srcset_2 -%}
          {%- for w in widths_mobile_list -%}
            {{ mobile_src_image_2 | image_url: width: w, format: 'webp' }} {{ w }}w{%- unless forloop.last -%}, {%- endunless -%}
          {%- endfor -%}
        {%- endcapture -%}

        <div class="banner__media{% if has_image_1 %} banner__media-half{% endif %}">
          <use-animate data-animate="zoom-fade" class="media-wrapper">
            <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
              <picture class="motion-reduce">
                <source media="(max-width: 749px)" srcset="{{ mobile_srcset_2 | strip_newlines | strip }}" sizes="{{ sizes_2nd }}">
                {%- echo image_2nd | image_url: width: 1100, format: 'webp' | image_tag:
                    loading: 'lazy',
                    fetchpriority: 'low',
                    decoding: 'async',
                    class: image_class_2nd,
                    sizes: sizes_2nd,
                    widths: widths_desktop,
                    is: 'lazy-image' -%}
              </picture>
            </div>
          </use-animate>
        </div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="banner__content banner__content--{{ section.settings.text_box_position }} page-width mobile-align-{{ section.settings.mobile_content_alignment }}">
          <div class="banner__box {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  <{{ block.settings.heading_tag }} class="banner__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                        hl_input: block.settings.heading, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                  </{{ block.settings.heading_tag }}>
                {%- when 'subheading' -%}
                  <p class="banner__subheading{% if block.settings.secondary_color %} banner__subheading--colored{% endif %} {{ block.settings.subheading_size }}" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                        hl_input: block.settings.subheading, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                  </p>
                {%- when 'text' -%}
                  <div class="banner__text{% if block.settings.secondary_color %} banner__text--colored{% endif %} {{ block.settings.text_size }} rte" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                        hl_input: block.settings.text, 
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true -%}
                  </div>
                {%- when 'custom_liquid' -%}
                  <div class="banner__text rte" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
                {%- when 'button' -%}
                  <div class="button-group">
                    {%- if block.settings.button_label != blank or block.settings.button_alt_label != blank -%}
                      {%- if block.settings.button_label != blank -%}
                        {%- if block.settings.button_style_secondary -%}
                          <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            <span class="label">{{ block.settings.button_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        {%- else -%}
                          <a class="button button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            {{ block.settings.button_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                      {%- if block.settings.button_alt_label != blank -%}
                        {%- if block.settings.button_alt_style_secondary -%}
                          <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            <span class="label">{{ block.settings.button_alt_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        {%- else -%}
                          <a class="button button--secondary button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            {{ block.settings.button_alt_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    {%- elsif section.blocks.size == 1 and block.settings.button_link != blank -%}
                      <a class="full-unstyled-link" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }}></a>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
            {%- if show_trust and section.settings.trust_strip_layout == 'inside' -%}
              <div class="banner__trust banner__trust--inside">
                {{ trust_items_html }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
  {%- if show_trust and section.settings.trust_strip_layout == 'below' -%}
    <div class="banner__trust banner__trust--below">
      {{ trust_items_html }}
    </div>
  {%- endif -%}
</div>

