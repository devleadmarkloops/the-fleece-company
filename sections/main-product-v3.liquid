{%- liquid

  assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  assign first_image = featured_media | default: product.media.first
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign product_form_id = 'product-form-' | append: section.id

  assign title_block = section.blocks | where: 'type', 'title' | first
  assign title_block_price = false
  if title_block.settings.show_price == true
    assign title_block_price = true
  endif

  assign needs_swiper = false
  assign pairs_well_block = section.blocks | where: 'type', 'pairs_well' | first
  assign video_reels_block = section.blocks | where: 'type', 'video_reels' | first
  if pairs_well_block or video_reels_block
    assign needs_swiper = true
  endif
-%}

{%- if needs_swiper -%}
  {% render 'swiper-loader' %}
{%- endif -%}


{% render 'product-v3-head-assets',
  product: product,
  section: section,
  featured_media: featured_media
%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding{% if section.settings.enable_v2_styles %} product-v2{% endif %}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  {% if collection and collection.handle %}
    data-url="{{ product.url | within: collection }}"
  {% else %}
    data-url="{{ product.url }}"
  {% endif %}
  {% comment %}
    {% if section.settings.image_zoom == 'hover' %}
      data-zoom-on-hover
    {% endif %}
  {% endcomment %}
>

  <section class="page-width section--padding">

    {% comment %} {% for block in section.blocks %}
      {% if block.type == 'breadcrumb' %}
        <div class="breadcrumb-wrapper{% if block.settings.hide_mobile %} small-hide{% endif %}" {{ block.shopify_attributes }}>
          {% render 'breadcrumbs',
            text_style: block.settings.text_style,
            show_divider: block.settings.show_divider
          %}
        </div>
      {% endif %}
    {% endfor %} {% endcomment %}

    {%- comment -%}
      CWV FIX (C2): reserva de altura no .product__media-wrapper antes do
      media-gallery/Swiper hidratar. Usamos aspect-ratio nativo com a razão
      da primeira imagem, então o wrapper ocupa exatamente a mesma área
      que a imagem LCP vai preencher. Se o aspect-ratio não estiver
      disponível (~<5% dos navegadores), fica sem reserva — sem regressão.

      Aplicado apenas ao wrapper (não aos filhos) para não interferir na
      geometria interna do <media-gallery>/Swiper.
    {%- endcomment -%}
    {%- liquid
      assign gallery_min_aspect = first_image.aspect_ratio | default: 1
    -%}
    <style>
      @supports (aspect-ratio: 1 / 1) {
        #MainProduct-{{ section.id }} .product__media-wrapper {
          aspect-ratio: {{ gallery_min_aspect }};
          min-height: 0;
          contain: layout;
        }
        @media screen and (min-width: 990px) {
          #MainProduct-{{ section.id }} .product__media-wrapper {
            aspect-ratio: {{ gallery_min_aspect }};
          }
        }
        /* Após hidratar, o gallery controla sua própria altura; limpamos
           a reserva para permitir que thumbnails/modo zoom funcionem. */
        #MainProduct-{{ section.id }} media-gallery.is-mounted ~ .product__media-wrapper,
        #MainProduct-{{ section.id }} .product__media-wrapper:has(media-gallery.is-mounted) {
          aspect-ratio: auto;
        }
      }
    </style>

    <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} flex-grid flex-grid--1-col {% if product.media.size > 0 %}flex-grid--2-col-tablet{% else %}product--no-media{% endif %}{% if section.settings.gallery_layout == 'thumbnail_slider' and section.settings.show_thumbnails == false %} product--hide-thumbnails{% endif %}{% if section.settings.image_ratio == 'adapt' %} product--adapt{% endif %}{% if section.settings.mobile_image_ratio == 'adapt' %} product--mobile-adapt{% endif %}{% unless section.settings.enable_image_zoom %} product--zoom-disabled{% endunless %}">
      <product-recently-viewed data-product-id="{{ product.id }}" class="hidden"></product-recently-viewed>
      <div class="flex-grid__item product__media-wrapper">
        <span id="ProductImages"></span>
        {% render 'product-v3-gallery',
          product: product,
          section: section,
          featured_media: featured_media
        %}
      </div>

      <div class="product__info-wrapper flex-grid__item">
        <div
          id="ProductInfo-{{ section.id }}"
          class="product__info-container{% if section.settings.enable_sticky_info %} product__info-container--sticky{% endif %}"
        >
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                {% render 'product-v3-block-text', block: block, product: product %}
              {%- when 'donation_impact' -%}
                {% render 'product-v3-block-donation-impact', block: block %}
              {%- when 'sku' -%}
                {% render 'product-v3-block-sku', block: block, product: product, section: section %}
              {%- when 'title' -%}
                {% render 'product-v3-block-title', block: block, product: product, section: section %}
              {%- when 'price' -%}
                {% render 'product-v3-block-price',
                  block: block,
                  product: product,
                  section: section,
                  title_block_price: title_block_price
                %}
              {%- when 'description' -%}
                {% render 'product-v3-block-description', block: block, product: product %}
              {%- when 'rating_static' -%}
                {% render 'product-v3-block-rating-static', block: block %}
              {%- when 'text_custom' -%}
                {% render 'product-v3-block-text-custom', block: block %}
              {%- when 'richtext_box' -%}
                {% render 'product-v3-block-richtext-box', block: block %}
              {%- when 'icon_text' -%}
                {% render 'product-v3-block-icon-text', block: block %}
              {%- when 'icon_text_grid' -%}
                {% render 'product-v3-block-icon-text-grid', block: block %}
              {%- when 'countdown_timer' -%}
                {% render 'product-v3-block-countdown-timer', block: block %}
              {%- when 'icon_with_text' -%}
                {% render 'product-v3-block-icon-with-text', block: block %}
              {%- when 'payment_icons' -%}
                {% render 'product-v3-block-payment-icons', block: block %}
              {%- when 'video_reels' -%}
                {% render 'product-v3-block-video-reels', block: block %}
              {%- when 'custom_liquid' -%}
                {% render 'product-v3-block-custom-liquid', block: block, section: section %}
              {%- when 'collapsible_description' -%}
                {% render 'product-v3-block-collapsible-description', block: block, product: product %}
              {%- when 'collapsible_tab' -%}
                {% render 'product-v3-block-collapsible-tab', block: block, section: section %}
              {%- when 'shipping_metaobject' -%}
                {% render 'product-v3-block-shipping-metaobject', block: block %}
              {%- when 'popup' -%}
                {% render 'product-v3-block-popup', block: block %}
              {%- when 'share' -%}
                {% render 'product-v3-block-share', block: block, product: product %}
              {%- when 'inventory_status' -%}
                {% render 'product-v3-block-inventory-status',
                  block: block,
                  product: product,
                  section: section
                %}
              {%- when 'variant_picker' -%}
                {% render 'product-v3-block-variant-picker',
                  block: block,
                  product: product,
                  product_form_id: product_form_id
                %}
              {%- when 'sibling_products' -%}
                {%- render 'sibling-products', block: block, product: product, section_id: section.id -%}
              {%- when 'buy_buttons' -%}
                {% render 'product-v3-block-buy-buttons',
                  block: block,
                  product: product,
                  section: section,
                  product_form_id: product_form_id
                %}
              {%- when 'rating' -%}
                {% render 'product-v3-block-rating', block: block, product: product %}
              {%- when 'related_buttons' -%}
                {% render 'product-v3-block-related-buttons', block: block, product: product %}
              {%- when 'image' -%}
                {% render 'product-v3-block-image', block: block %}
              {%- when 'countdown' -%}
                {% render 'product-v3-block-countdown', block: block, product: product %}
              {%- when 'separator' -%}
                {% render 'product-v3-block-separator', block: block %}
              {%- when 'spacing' -%}
                {% render 'product-v3-block-spacing', block: block %}
              {%- when 'complementary' -%}
                {% render 'product-v3-block-complementary',
                  block: block,
                  product: product,
                  section: section
                %}
              {%- when 'pairs_well' -%}
                {% render 'product-v3-block-pairs-well', block: block, product: product %}
              {%- when 'line_item_property' -%}
                {% render 'product-v3-block-line-item-property',
                  block: block,
                  product_form_id: product_form_id,
                  section: section
                %}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    {% render 'product-media-modal', product: product, variant_images: variant_images %}

    {% render 'product-v3-modals', product: product, section: section %}

    {% render 'product-v3-sticky-cart',
      product: product,
      section: section,
      featured_media: featured_media,
      first_image: first_image
    %}
  </section>

  {% render 'product-v3-footer-scripts',
    product: product,
    section: section,
    first_3d_model: first_3d_model
  %}
</product-info>

{% render 'product-v3-outer-scripts', section: section %}

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "donation_impact",
      "name": "Donation Impact",
      "settings": [
        {
          "type": "select",
          "id": "display",
          "label": "Display",
          "options":[
            {
              "label":"Desktop",
              "value":"desktop"
            },
            {
              "label":"Mobile",
              "value":"mobile"
            },
            {
              "label":"Both",
              "value":"both"
            }
          ],
          "default":"both"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image",
          "info": "Custom icon (heart, charity logo, etc). Falls back to heart SVG if empty."
        },
        {
          "type": "range",
          "id": "icon_size",
          "min": 16,
          "max": 60,
          "step": 2,
          "default": 24,
          "unit": "px",
          "label": "Icon Size"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Your order donates $1 to support women escaping abuse"
        },
        {
          "type": "number",
          "id": "raised",
          "label": "Amount Raised (fallback)",
          "default": 6847,
          "info": "Used if metafield custom.donations_raised is not set"
        },
        {
          "type": "number",
          "id": "goal",
          "label": "Goal Amount (fallback)",
          "default": 10000
        },
        {
          "type": "number",
          "id": "orders_remaining",
          "label": "Orders Remaining (fallback)",
          "default": 800
        },
        {
          "type": "checkbox",
