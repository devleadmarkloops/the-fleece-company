{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    
    {%- if section.settings.use_custom_colors %}
      --color-background: {{ section.settings.colors_background }};
      --color-foreground: {{ section.settings.colors_text }};
      --color-heading: {{ section.settings.colors_text }};
    {% endif -%}
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top_mob }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }

  {%- if section.settings.use_custom_colors %}
    #shopify-section-{{ section.id }} .icon-info-wrapper {
      background-color: var(--color-background);
      color: var(--color-foreground);
    }
    #shopify-section-{{ section.id }} .title {
      color: var(--color-foreground);
    }
  {%- endif -%}

  {% if section.settings.enable_separator %}
    #shopify-section-{{ section.id }} .icon-info-wrapper {
      border-bottom: .1rem solid rgb(var(--color-border));
    }
  {% endif %}

  /* --- HEADER --- */
  #shopify-section-{{ section.id }} .title-wrapper {
    margin-bottom: 4rem;
    text-align: {{ section.settings.heading_alignment }};
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .title {
    margin: 0;
    font-family: var(--new-font-heading-family);
  }
  #shopify-section-{{ section.id }} .icon-info-grid {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .icon-info-grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
      gap: 4rem;
    }
  }

  .icon-info-card {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .icon-info-card__icon {
    width: {{ section.settings.icon_size_mobile }}px;
    height: {{ section.settings.icon_size_mobile }}px;
    object-fit: contain;
  }

  @media screen and (min-width: 750px) {
    .icon-info-card__icon {
      width: {{ section.settings.icon_size }}px;
      height: {{ section.settings.icon_size }}px;
    }
  }

  .icon-info-card__subtext {
    margin: 0;
    font-family: var(--new-font-body-family);
    font-size: 1.4rem; /* 14px */
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    color: rgba(var(--color-foreground), 0.7);
  }
  .icon-info-card__heading {
    margin: 0;
    font-family: var(--new-font-body-family);
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1.2;
    color: rgb(var(--color-foreground));
  }
  .icon-info-card__heading a {
    color: rgb(var(--color-foreground));
    background: none;
    background-image: none;
    text-decoration: none;
  }
  .icon-info-card__heading p {
    margin: 0;
  }
  .icon-info-card__heading a {
    color: inherit;
    /* text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.3s ease; */
  }
  .icon-info-card__heading a:hover {
    opacity: 0.85;
  }
  .icon-info-card__desc {
    margin: 0;
    font-family: var(--new-font-body-family);
    font-size: 1.4rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.85);
  }

  @media screen and (max-width: 749px) {
    .icon-info-card {
      gap: 1rem;
    }
  }
{%- endstyle -%}

<div class="icon-info-wrapper section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="title-wrapper">
        <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      </div>
    {%- endif -%}

    <div class="icon-info-grid">
      {%- for block in section.blocks -%}
        <div class="icon-info-card" style="align-items: {{ block.settings.alignment }}; text-align: {{ block.settings.alignment | replace: 'flex-start', 'left' | replace: 'center', 'center' | replace: 'flex-end', 'right' }};" {{ block.shopify_attributes }}>
          
          {%- if block.settings.icon != blank -%}
            {{ block.settings.icon | image_url: width: 200 | image_tag: loading: 'lazy', class: 'icon-info-card__icon' }}
          {%- endif -%}

          {%- if block.settings.subtext != blank -%}
            <div class="icon-info-card__subtext">{{ block.settings.subtext }}</div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <div class="icon-info-card__heading">{{ block.settings.heading }}</div>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="icon-info-card__desc">{{ block.settings.text }}</div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Icon Info Columns",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide."
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p", "label": "Paragraph" }
      ],
      "default": "h2",
      "label": "Heading SEO Tag"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Icon Sizing"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Size (Mobile)",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "enable_separator",
      "default": false,
      "label": "Enable separator"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "default": false,
      "label": "Use Custom Colors"
    },
    {
      "type": "color",
      "id": "colors_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "colors_text",
      "label": "Text",
      "default": "#212326"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": false,
      "label": "Show Top/Bottom Divider"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Info Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Top Text (14px)",
          "default": "Contact Us"
        },
        {
          "type": "richtext",
          "id": "heading",
          "label": "Middle Heading (18px)",
          "default": "<p>hello@yourstore.com</p>",
          "info": "Highlight text to add links (like mailto: or tel:)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Bottom Text (14px)",
          "default": "Available Mon-Fri, 9am-5pm."
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Content Alignment",
          "options": [
            { "value": "flex-start", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Right" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Info Columns",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}