{%- comment %}
  Name: Announcement Bar Multi
  Description: A multi-announcement carousel using Swiper with full touch/swipe support
{%- endcomment -%}

{%- liquid
  assign show_announcement_bar = true

  if section.blocks.size == 0
    assign show_announcement_bar = false
  endif

  if section.settings.only_homepage and request.page_type != 'index'
    assign show_announcement_bar = false
  endif

  assign announcement_blocks = section.blocks | where: 'type', 'announcement'
  assign has_announcements = false
  if announcement_blocks.size > 0
    assign has_announcements = true
  endif
-%}

{%- if show_announcement_bar and has_announcements -%}
  {%- style -%}
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
      --abm-gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --abm-color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --abm-color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --abm-color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
      --abm-font-family: {{ section.settings.font_family }};
      --abm-font-size: {{ section.settings.font_size }}px;
      --abm-font-size-mobile: {{ section.settings.font_size_mobile }}px;
    }
  {%- endstyle -%}

  <link rel="stylesheet" href="{{ 'section-announcement-bar-multi.css' | asset_url }}">

<div class="announcement-bar-multi" role="region" aria-label="{{ 'accessibility.site_announcements' | t }}">
    <div class="page-width announcement-bar-multi__wrapper">
      {%- if section.settings.show_navigation and announcement_blocks.size > 1 -%}
        <div class="announcement-button-prev announcement-button-desktop">
          {% render 'icon', icon: 'chevron-alt' %}
        </div>
      {%- endif -%}

      {%- if section.settings.show_navigation_mobile and announcement_blocks.size > 1 -%}
        <div class="announcement-button-prev announcement-button-mobile">
          {% render 'icon', icon: 'chevron-alt' %}
        </div>
      {%- endif -%}

      <div class="swiper" id="announcement-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in announcement_blocks -%}
            <div class="swiper-slide announcement-slide" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a class="announcement-link" href="{{ block.settings.link }}">
              {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <span class="announcement-text">
                    {%- render 'highlight-text', 
                      hl_input: block.settings.text, 
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: false -%}
                  </span>
                {%- endif -%}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.settings.show_navigation and announcement_blocks.size > 1 -%}
        <div class="announcement-button-next announcement-button-desktop">
          {% render 'icon', icon: 'chevron-alt' %}
        </div>
      {%- endif -%}

      {%- if section.settings.show_navigation_mobile and announcement_blocks.size > 1 -%}
        <div class="announcement-button-next announcement-button-mobile">
          {% render 'icon', icon: 'chevron-alt' %}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_pagination and announcement_blocks.size > 1 -%}
      <div class="announcement-bar-multi__pagination announcement-pagination-desktop">
        <div class="swiper-pagination"></div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_pagination_mobile and announcement_blocks.size > 1 -%}
      <div class="announcement-bar-multi__pagination announcement-pagination-mobile">
        <div class="swiper-pagination"></div>
      </div>
    {%- endif -%}
  </div>

  <script>
    (function() {
      function initAnnouncementSwiper() {
        var container = document.querySelector('#announcement-swiper-{{ section.id }}');
        if (!container || container.swiper) return;

        var section = container.closest('.announcement-bar-multi');
        var blockCount = {{ announcement_blocks.size }};

        var swiperConfig = {
          loop: blockCount > 1,
          grabCursor: true,
          simulateTouch: true,
          allowTouchMove: true,
          navigation: {
            prevEl: section.querySelector('.announcement-button-prev:not(.announcement-button-mobile)'),
            nextEl: section.querySelector('.announcement-button-next:not(.announcement-button-mobile)'),
          },
          pagination: {
            el: section.querySelector('.announcement-pagination-desktop .swiper-pagination') || section.querySelector('.announcement-pagination-mobile .swiper-pagination'),
            clickable: true,
          },
          {%- if section.settings.autorotate and announcement_blocks.size > 1 -%}
          autoplay: {
            delay: {{ section.settings.autorotate_speed }} * 1000,
            disableOnInteraction: false,
          },
          {%- endif -%}
          effect: '{{ section.settings.effect }}',
          {%- if section.settings.effect == 'slide' -%}
          cubeEffect: {
            slideShadows: false,
            shadow: false,
            shadowOffset: 0,
            shadowScale: 0,
          },
          {%- else -%}
          fadeEffect: {
            crossFade: true,
          },
          {%- endif -%}
          speed: {{ section.settings.speed }},
          watchSlidesProgress: true,
        };

        container.swiper = new Swiper(container, swiperConfig);
      }

      if (typeof Swiper !== 'undefined') {
        initAnnouncementSwiper();
      } else {
        window.addEventListener('load', initAnnouncementSwiper);
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar Multi",
  "class": "shopify-section-announcement-bar-multi",
  "max_blocks": 10,
  "settings": [
    {
      "type": "checkbox",
      "id": "only_homepage",
      "label": "t:sections.announcement-bar.settings.only_homepage.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "select",
      "id": "effect",
      "label": "Transition effect",
      "options": [
        {"value": "slide", "label": "Slide"},
        {"value": "fade", "label": "Fade"}
      ],
      "default": "slide"
    },
    {
      "type": "checkbox",
      "id": "autorotate",
      "default": true,
      "label": "Auto-rotate announcements"
    },
    {
      "type": "range",
      "id": "autorotate_speed",
      "label": "Rotation interval",
      "max": 10,
      "min": 2,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Transition speed",
      "max": 1000,
      "min": 300,
      "step": 100,
      "unit": "ms",
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "default": true,
      "label": "Show navigation arrows (desktop)"
    },
    {
      "type": "checkbox",
      "id": "show_navigation_mobile",
      "default": false,
      "label": "Show navigation arrows (mobile)"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "default": true,
      "label": "Show pagination dots (desktop)"
    },
    {
      "type": "checkbox",
      "id": "show_pagination_mobile",
      "default": false,
      "label": "Show pagination dots (mobile)"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "options": [
        {"value": "var(--font-heading-family)", "label": "Heading"},
        {"value": "var(--font-body-family)", "label": "Body"},
        {"value": "var(--new-font-body-family)", "label": "Body (new)"},
        {"value": "var(--font-body-family), sans-serif", "label": "Custom 1"},
        {"value": "var(--font-heading-family), sans-serif", "label": "Custom 2"}
      ],
      "default": "var(--font-body-family)"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (desktop)",
      "max": 24,
      "min": 10,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "max": 20,
      "min": 10,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.header.content"
    },
    {
      "type": "color",
      "id": "colors_text",
      "label": "t:sections.all.colors.colors_text.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "colors_background",
      "label": "t:sections.all.colors.colors_background.label",
      "default": "#1a1b18"
    },
    {
      "type": "color_background",
      "id": "gradient_background",
      "label": "t:sections.all.colors.gradient_background.label"
    },
    {
      "type": "color",
      "id": "colors_highlight",
      "label": "t:sections.all.colors.colors_highlight.label",
      "default": "#ffb503"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Welcome to our store",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "header",
          "content": "t:sections.all.highlight.header.content"
        },
        {
          "type": "checkbox",
          "id": "enable_highlight",
          "label": "t:sections.all.highlight.enable.label",
          "default": false
        },
        {
          "type": "select",
          "id": "highlight_style",
          "options": [
            {"value": "marker", "label": "t:sections.all.highlight.style.options__1.label"},
            {"value": "circle", "label": "t:sections.all.highlight.style.options__2.label"},
            {"value": "underline", "label": "t:sections.all.highlight.style.options__3.label"},
            {"value": "bold-underline", "label": "t:sections.all.highlight.style.options__4.label"}
          ],
          "default": "marker",
          "label": "t:sections.all.highlight.style.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar Multi",
      "blocks": [
        {"type": "announcement"},
        {"type": "announcement"},
        {"type": "announcement"}
      ]
    }
  ]
}
{% endschema %}