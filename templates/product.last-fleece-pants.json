        "text_custom_A3eeDw": {
          "type": "text_custom",
          "settings": {
            "text_custom": "<strong>The Coziest Sweatpants of the Year </strong>Our Premium Fleece Sweatpants is an embodiment of oversized comfort & style. Made with 100% skin-friendly materials. This breathable fleece will keep you cozy all year round. Its ultra-soft oversized fit wraps you in warmth like a blanket.",
            "text_color": "",
