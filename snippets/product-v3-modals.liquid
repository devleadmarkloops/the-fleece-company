{% comment %}
  Renders the product page modal dialogs for main-product-v3:
  - Popup modals loop (one <modal-dialog> per block of type 'popup')
  - Size chart modal (from the variant_picker block's size_chart setting, if any)

  Accepts:
  - product: {Object} Product object (reserved for future parity)
  - section: {Object} Section object (provides section.blocks for filtering popups / variant_picker)

  Note: {% render 'product-media-modal' ... %} is emitted directly in main-product-v3.liquid
  (not inside this snippet) to keep the structural boundary explicit.

  Mechanical extraction of lines 2689-2739 of main-product-v2.liquid. No optimizations applied.
{% endcomment %}

    {%- assign popups = section.blocks | where: 'type', 'popup' -%}
    {%- for block in popups -%}
      <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal">
        <div
          role="dialog"
          aria-label="{{ block.settings.link_label }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="icon icon-plus-alt"></span>
          </button>
          <div class="product-popup-modal__content-info">
            <div class="h2">{{ block.settings.page.title }}</div>
            <div class="rte">{{ block.settings.page.content }}</div>
          </div>
        </div>
      </modal-dialog>
    {%- endfor -%}

    {%- assign block_variant_picker = section.blocks | where: 'type', 'variant_picker' | first -%}
    {%- if block_variant_picker and block_variant_picker.settings.size_chart != blank -%}
      <modal-dialog id="PopupModal-{{ block_variant_picker.id }}" class="product-popup-modal">
        <div
          role="dialog"
          aria-label="{{ block_variant_picker.settings.link_label }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block_variant_picker.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="icon icon-plus-alt"></span>
          </button>
          <div class="product-popup-modal__content-info">
            <div class="h2">{{ block_variant_picker.settings.size_chart.title }}</div>
            <div class="rte">{{ block_variant_picker.settings.size_chart.content }}</div>
          </div>
        </div>
      </modal-dialog>
    {%- endif -%}
