{% comment %}
  Dispatcher for buy_buttons variants (v1/v2/v3/default).

  Accepts:
  - block:            {Object} Block object
  - product:          {Object} Product object
  - product_form_id:  {String} Shared form id
  - section:          {Object} Section object

  Mechanical extraction of the 'buy_buttons' case from main-product-v2.liquid (lines 2169-2218).
{% endcomment %}

{%- case block.settings.buy_buttons_version -%}
  {%- when 'v1' -%}
    {% render 'buy-buttons-v1',
      block: block,
      product: product,
      section_id: section.id,
      product_form_id: product_form_id,
      show_pickup_availability: true
    %}
    {% if block.settings.icon_text != blank %}
      <div class="btn-icon-text-wr">
        {% if block.settings.icon != blank %}
          <img src="{{ block.settings.icon | image_url }}" width="20" height="20" alt="Icon">
        {% endif %}
        <span class="btn-icon-text">{{ block.settings.icon_text }}</span>
      </div>
    {% endif %}
    <div class="installment-text" {{ block.shopify_attributes }}>
      {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
      {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {{ form | payment_terms }}
      {%- endform -%}
    </div>
  {%- when 'v2' -%}
    {% render 'buy-buttons-v2',
      block: block,
      product: product,
      section_id: section.id,
      product_form_id: product_form_id,
      show_pickup_availability: true
    %}
  {%- when 'v3' -%}
    {% render 'buy-buttons-v3',
      block: block,
      product: product,
      section_id: section.id,
      product_form_id: product_form_id,
      show_pickup_availability: true
    %}
  {%- else -%}
    {% render 'buy-buttons',
      block: block,
      product: product,
      section_id: section.id,
      product_form_id: product_form_id,
      show_pickup_availability: true
    %}
{%- endcase -%}
