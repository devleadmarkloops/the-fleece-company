{% comment %}
  Renders the static rating block.

  Accepts:
  - block:   {Object} Block object
  - product: {Object} Product object
  - section: {Object} Section object

  Mechanical extraction of the 'rating_static' case from main-product-v2.liquid (lines 1364-1430).
{% endcomment %}

<div class="rating-static-wr" {{ block.shopify_attributes }}>
  <div class="stars-wr">
    {% for i in (1..5) %}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor">
        <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"></path>
      </svg>
    {% endfor %}
  </div>
  <span class="r-text">{{ block.settings.rating_text }}</span>
  {% if block.settings.rating_link != blank %}
    <a class="rating-link" href="{{ block.settings.rating_link }}"></a>
  {% else %}
    <button type="button" class="rating-link-scroll" aria-label="Scroll to reviews"></button>
  {% endif %}
  {% if block.settings.enable_price %}
    <div class="{% if block.settings.desktop_hide %} large-up-hide medium-hide{% endif %}{% if block.settings.mobile_hide %} small-hide{% endif %}" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
      {%- liquid
        assign show_badges = block.settings.show_badges
        assign price_class = 'price--' | append: block.settings.price_size
        render 'price', product: product, use_variant: true, show_badges: show_badges, price_class: price_class, sale_badge_basis: block.settings.sale_badge_basis
      -%}
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const ratingLinks = document.querySelectorAll('.rating-link-scroll');

    ratingLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        // Find the reviews slider section
        const reviewsSection = document.querySelector('[class*="reviews-slider"]') ||
                              document.querySelector('.reviews-slider-wr') ||
                              document.querySelector('[data-section-type="reviews"]');

        if (reviewsSection) {
          reviewsSection.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  });
</script>

<style>
  .rating-link-scroll {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .rating-static-wr {
    position: relative;
    /* CWV FIX (C8): reserva de altura para evitar CLS se o Judge.me ou
       outro widget de review enxertar conteúdo neste bloco após o first
       paint. As 5 estrelas renderizam com ~20px de altura; valor abaixo
       cobre estrelas + texto com folga para 1 linha. */
    min-height: 24px;
  }
</style>
