{% comment %}
  Renders the shipping_metaobject block (accordion with market-specific shipping text).

  Accepts:
  - block: {Object} Block object

  Mechanical extraction of the 'shipping_metaobject' case from main-product-v2.liquid (lines 2044-2080).
{% endcomment %}

{%- assign metaobject_data = block.settings.shipping_text -%}

{%- if metaobject_data != blank -%}
  <accordion-tab class="product__accordion accordion" {{ block.shopify_attributes }}>
    <details
      {% if block.settings.keep_open %}
        open
      {% endif %}
    >
      <summary>
        <span class="summary__title">
          {% render 'icon-accordion', icon: block.settings.icon %}
          <span class="accordion__title">
            {{ block.settings.heading | default: metaobject_data.system.name | escape }}
          </span>
        </span>
        {% render 'icon', icon: 'plus' %}
      </summary>
      <div class="accordion__content rte">
        {%- if metaobject_data.market != blank -%}
          {% comment %}
            <div class="metaobject-market">
              <strong>Market:</strong> {{ metaobject_data.market }}
            </div>
          {% endcomment %}
        {%- endif -%}

        {%- if metaobject_data.shipping_return != blank -%}
          <div class="metaobject-shipping-content">
            {{ metaobject_data.shipping_return | metafield_tag }}
          </div>
        {%- endif -%}
      </div>
    </details>
  </accordion-tab>
{%- endif -%}
