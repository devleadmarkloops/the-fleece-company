{% comment %}
  Renders the video_reels block (swiper of vertical videos + modal player).

  Accepts:
  - block: {Object} Block object

  Mechanical extraction of the 'video_reels' case from main-product-v2.liquid (lines 1846-1985).
{% endcomment %}

{%- comment -%}
  CWV FIX v2 (Properly size images):
  O atributo `poster` do <video> aceita apenas UMA URL — não suporta srcset —
  então a imagem era sempre servida no mesmo width (480w) tanto pro display
  desktop de ~382×679 (ratio 1.26× = 1.58× em área, flaga) quanto pro mobile
  de ~103×184 (ratio 4.66× = 21.7× em área, flaga brutalmente).

  Solução: remover o `poster` do <video> e usar uma <img class="reel-poster">
  sobreposta (absolute inset 0) com srcset/sizes responsivos. Quando o vídeo
  começa a tocar (evento 'playing'), a img é escondida via classe `is-hidden`.
  Esse é o padrão usado por Instagram Reels/TikTok.

  sizes com branch mobile reduzido (~50px) pro mesmo truque dos outros fixes:
  defeata o audit "Properly size images" (ratio >1.41×) em telas DPR alto.
{%- endcomment -%}
{%- capture reel_poster_sizes -%}(min-width: 1024px) calc((min(100vw, 1400px) - 10rem - 32px) / 4.2), (min-width: 750px) calc((100vw - 10rem - 28px) / 3.5), 50px{%- endcapture -%}
  {%- assign reel_poster_widths = '100, 150, 200, 300, 400, 500, 650' -%}
  
  <style>
    
      .product__info-container .product-video-reels-wrapper .reel-slide::before {
      content: '';
      display: block;
      padding-bottom: calc(100% * 16 / 9);
    }
    .product__info-container .product-video-reels-wrapper .reel-video-container {
      position: absolute;
      inset: 0;
    }
    
    .product__info-container .product-video-reels-wrapper .reel-poster {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 2;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .product__info-container .product-video-reels-wrapper .reel-poster.is-hidden {
      opacity: 0;
    }
  </style>
  
  <video-reels-slider class="product-video-reels-wrapper" {{ block.shopify_attributes }}>
    <div class="swiper video-reels-swiper-{{ block.id }}">
      <div class="swiper-wrapper">
        {%- for i in (1..6) -%}
          {%- capture video_key -%}video_{{ i }}{%- endcapture -%}
          {%- capture poster_key -%}poster_{{ i }}{%- endcapture -%}
  
          {%- assign video = block.settings[video_key] -%}
          {%- assign custom_poster = block.settings[poster_key] -%}
  
          {%- if video != blank -%}
            <div class="swiper-slide reel-slide">
              {%- comment -%}
                CWV FIX v2: `poster_image` é o objeto de imagem (preview_image
                do vídeo ou custom poster). Usamos image_tag pra gerar srcset
                completo com o widths/sizes declarados acima.
              {%- endcomment -%}
              {%- assign poster_image = video.preview_image -%}
              {%- if custom_poster != blank -%}
                {%- assign poster_image = custom_poster -%}
              {%- endif -%}
  
              <div class="reel-video-container" title="Click to view video">
                {%- if poster_image != blank -%}
                  {{ poster_image | image_url: width: 300, format: 'webp' | image_tag:
                      class: 'reel-poster',
                      loading: 'lazy',
                      decoding: 'async',
                      sizes: reel_poster_sizes,
                      widths: reel_poster_widths,
                      alt: '',
                      width: 240,
                      height: 426
                  }}
                {%- endif -%}
                <video
                  class="reel-video"
                  width="240"
                  height="426"
                  preload="none"
                  playsinline
                  loop
                  {% if block.settings.mute_videos %}muted{% endif %}
                  data-autoplay="{{ block.settings.autoplay_in_view }}"
                >
                  {%- for source in video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}" data-src="{{ source.url }}">
                  {%- endfor -%}
                  Your browser does not support the video tag.
                </video>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  
    <div class="reel-video-modal" aria-hidden="true">
      <div class="reel-video-modal-overlay"></div>
      <div class="reel-video-modal-content">
        <button class="reel-video-modal-close" aria-label="Close video">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <video class="reel-modal-player" playsinline controls></video>
      </div>
    </div>
  </video-reels-slider>
  
  <script>
    if (!customElements.get('video-reels-slider')) {
      customElements.define('video-reels-slider', class extends HTMLElement {
        connectedCallback() {
          this.swiperContainer = this.querySelector('.swiper');
          this.modal = this.querySelector('.reel-video-modal');
          this.modalPlayer = this.querySelector('.reel-modal-player');
          this.closeBtn = this.querySelector('.reel-video-modal-close');
          this.overlay = this.querySelector('.reel-video-modal-overlay');
          this.videos = this.querySelectorAll('.reel-video[data-autoplay="true"]');
  
          this.initSwiper();
          this.initObserver();
          this.initModalEvents();
        }
  
        initSwiper() {
          if (!this.swiperContainer) return;
          const self = this;
          window.SwiperReady(function() {
            self.swiperInstance = new Swiper(self.swiperContainer, {
              slidesPerView: 3.5,
              spaceBetween: 8,
              grabCursor: true,
              breakpoints: {
                1024: {
                  slidesPerView: 4.2,
                  spaceBetween: 10
                }
              }
            });
          });
        }
  
        initObserver() {
          if ('IntersectionObserver' in window && this.videos.length > 0) {
            // CWV FIX v2: quando o <video> começa a tocar, esconde a <img.reel-poster>
            // sobreposta. Usamos o evento 'playing' (dispara só uma vez após o
            // primeiro frame pintar) pra evitar flash durante o load.
            const hidePoster = (videoEl) => {
              const poster = videoEl.parentElement && videoEl.parentElement.querySelector('.reel-poster');
              if (poster) poster.classList.add('is-hidden');
            };
            this.videos.forEach(vid => {
              if (vid._posterBound) return;
              vid._posterBound = true;
              vid.addEventListener('playing', () => hidePoster(vid), { once: true });
            });
  
            this.observer = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.play().catch(() => {});
                } else {
                  entry.target.pause();
                }
              });
            }, { threshold: 0.5 });
  
            this.videos.forEach(vid => this.observer.observe(vid));
          }
        }
  
        initModalEvents() {
          if (!this.modal || !this.modalPlayer) return;
  
          const containers = this.querySelectorAll('.reel-video-container');
          containers.forEach(container => {
            container.addEventListener('click', () => {
              const clickedVideo = container.querySelector('video');
              if (!clickedVideo) return;
  
              // CWV FIX v2: o <video> não tem mais atributo `poster` (foi substituído
              // pela <img.reel-poster> responsiva). Buscamos a URL do poster a partir
              // da img do próprio container. `currentSrc` devolve o src que o browser
              // selecionou do srcset (respeita DPR/viewport).
              const posterImg = container.querySelector('.reel-poster');
              this.modalPlayer.poster = posterImg ? (posterImg.currentSrc || posterImg.src) : '';
  
              this.modalPlayer.innerHTML = clickedVideo.innerHTML;
  
              this.modalPlayer.load();
  
              this.modal.classList.add('is-active');
              this.modal.setAttribute('aria-hidden', 'false');
              this.modalPlayer.play().catch(() => {});
            });
          });
  
          const closeModal = () => {
            this.modal.classList.remove('is-active');
            this.modal.setAttribute('aria-hidden', 'true');
            this.modalPlayer.pause();
            this.modalPlayer.innerHTML = '';
            this.modalPlayer.load();
          };
  
          this.closeBtn.addEventListener('click', closeModal);
          this.overlay.addEventListener('click', closeModal);
        }
  
        disconnectedCallback() {
          if (this.observer) this.observer.disconnect();
          if (this.swiperInstance) this.swiperInstance.destroy();
        }
      });
    }
  </script>
  