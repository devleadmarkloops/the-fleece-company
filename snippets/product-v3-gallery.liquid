{% comment %}
  Renders the full media gallery for main-product-v3:
  - <media-gallery> custom element wrapper
  - Main slider (<product-gallery> + <use-animate>) with variant-specific media filtering,
    'gang' (variant-tied) media support, and featured_media resolution
  - Optional "iwt_gallery" static badge block rendered inside the gallery
  - XR button when a 3D model is present
  - <thumbnail-slider> desktop thumbnails (for thumbnail_slider/vertical_slider layouts)
  - Optional <product-thumbnails> "stacked" layout thumbnails column
  - Inline <script> that wires thumbnail nav, touch swipe, slider-button state,
    and MutationObserver to re-evaluate on DOM mutations

  Accepts:
  - product:        {Object}  Product object
  - section:        {Object}  Section object (for section.id, section.settings.*)
  - featured_media: {Object}  Pre-resolved featured media (defined earlier in parent via product.selected_or_first_available_variant.featured_media | default: product.featured_media)

  Relies on parent-defined assigns:
  - featured_media
  - first_3d_model (from product-v3-head-assets)

  Mechanical extraction of lines 246-1186 of main-product-v2.liquid. No optimizations applied.
{% endcomment %}

        <media-gallery
          id="MediaGallery-{{ section.id }}"
          role="region"
          {% if section.settings.enable_sticky_info %}
            class="product__media-gallery"
          {% endif %}
          aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
          data-desktop-layout="{{ section.settings.gallery_layout }}"
          data-gallery-nav
          data-section-id="{{ section.id }}"
        >
          <div id="GalleryStatus-{{ section.id }}" class="visually-hidden" role="status"></div>
          <use-animate data-animate="zoom-fade">
            <product-gallery id="GalleryViewer-{{ section.id }}" class="slider-mobile-gutter slider-mobile--overlay{% if section.settings.enable_fade_slider %} slider--fade{% endif %}">
              <a class="skip-to-content-link button visually-hidden" href="#ProductInfo-{{ section.id }}">
                {{ 'accessibility.skip_to_product_info' | t }}
              </a>
              {% comment %}
                {% if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true %}
                  {% assign fi_variant = product.selected_or_first_available_variant %}
                  <ul
                    id="Slider-Gallery-{{ section.id }}"
                    class="product__media-list flex-grid flex-grid--1-col flex-grid--1-col-tablet slider slider--mobile"
                    role="list"
                  >
                    {% if fi_variant.featured_media != blank %}
                      <li
                        id="Slide-{{ section.id }}-{{ featured_media.id }}"
                        class="product__media-item is-active flex-grid__item slider__slide{% if single_media_visible %} product__media-item--single{% endif %}{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.hide_variants and variant_images contains featured_media.src %} product__media-item--variant{% endif %}{% if gang_media_active == true %} gang__active{% endif %}"
                        data-media-id="{{ section.id }}-{{ featured_media.id }}"
                        data-media-position="{{ featured_media.position }}"
                        {% if gang_exist == true %}
                          data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                        {% endif %}
                      >
                        {% render 'product-image',
                          media: fi_variant.featured_media,
                          position: 'featured',
                          zoom: section.settings.enable_image_zoom,
                          loop: section.settings.enable_video_looping,
                          modal_id: section.id,
                          xr_button: true,
                          media_width: 0.55,
                          image_ratio: 'adapt',
                          mobile_image_ratio: 'adapt',
                          lazy_load: false
                        %}
                      </li>
                    {% endif %}
                    {% for media in product.media %}
                      {% assign v_title = fi_variant.title | downcase | replace: ' ', '' %}
                      {% assign media_alt = media.alt | downcase | replace: ' ', '' %}
                      {% if v_title contains media_alt and media.id != fi_variant.featured_media.id %}
                        <li
                          id="Slide-{{ section.id }}-{{ featured_media.id }}"
                          class="product__media-item is-active flex-grid__item slider__slide{% if single_media_visible %} product__media-item--single{% endif %}{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.hide_variants and variant_images contains featured_media.src %} product__media-item--variant{% endif %}{% if gang_media_active == true %} gang__active{% endif %}"
                          data-media-id="{{ section.id }}-{{ featured_media.id }}"
                          data-media-position="{{ featured_media.position }}"
                          {% if gang_exist == true %}
                            data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                          {% endif %}
                        >
                          {% render 'product-image',
                            media: media,
                            position: forloop.index,
                            zoom: section.settings.enable_image_zoom,
                            loop: section.settings.enable_video_looping,
                            modal_id: section.id,
                            xr_button: true,
                            media_width: 0.55,
                            image_ratio: 'adapt',
                            mobile_image_ratio: 'adapt',
                            lazy_load: false
                          %}
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% else %}
              {% endcomment %}
              <ul
                id="Slider-Gallery-{{ section.id }}"
                class="product__media-list flex-grid flex-grid--1-col flex-grid--1-col-tablet slider slider--mobile{% if section.settings.enable_fade_slider %} slider--fade{% endif %}"
                role="list"
              >
                {%- liquid
                  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
                  if section.settings.hide_variants and variant_images.size == product.media.size
                    assign single_media_visible = true
                  endif

                  assign media_count = product.media.size
                  if section.settings.hide_variants and media_count > 1
                    assign media_count = media_count | minus: variant_images.size | plus: 1
                  endif

                  assign gang_exist = false

                  if section.settings.media_size == 'large'
                    assign media_width = 0.65
                  elsif section.settings.media_size == 'medium'
                    assign media_width = 0.55
                  elsif section.settings.media_size == 'small'
                    assign media_width = 0.45
                  endif

                  assign image_ratio = 'adapt'
                  if section.settings.gallery_layout != 'stacked'
                    assign image_ratio = section.settings.image_ratio
                  endif

                  assign mobile_image_ratio = section.settings.mobile_image_ratio
                -%}

                                {%- liquid
                  assign featured_media_matches = true
                  if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true
                    assign v_title = product.selected_or_first_available_variant.title | downcase | replace: ' ', ''
                    assign media_alt = featured_media.alt | downcase | replace: ' ', ''
                    
                    if media_alt != blank and v_title contains media_alt
                      assign featured_media_matches = true
                    elsif media_alt == blank
                      assign featured_media_matches = true
                    else
                      assign featured_media_matches = false
                    endif
                    
                    if featured_media.id == product.selected_or_first_available_variant.featured_media.id
                      assign featured_media_matches = true
                    endif
                  endif
                -%}
                {%- assign gallery_index = 0 -%}
        {%- assign featured_media_rendered = false -%}
        {%- if featured_media != blank and featured_media_matches -%}
          {%- assign featured_media_rendered = true -%}
          {%- assign gallery_index = gallery_index | plus: 1 -%}
                  {%- liquid
                    assign gang_option_name = ''
                    assign gang_media_active = false
                    assign gang_connect = ''
                    if featured_media.alt contains '#' and section.settings.hide_variants == false
                      assign gang_connect = featured_media.alt | split: '#' | last
                      if gang_connect contains ':' and localization.language.iso_code != blank
                        assign gang_connect = gang_connect | append: ','
                        assign split_param = localization.language.iso_code | append: ':'
                        assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                      endif
                      if gang_connect contains '_'
                        assign gang_exist = true
                        assign gang_option_name = gang_connect | split: '_' | first | handleize

                        for option in product.options_with_values
                          assign option_name_handlized = option.name | handleize | replace: '_', '-'
                          if option_name_handlized == gang_option_name
                            assign current_option_value = option.selected_value | handleize
                            assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                            if gang_connect == current_connect
                              assign gang_media_active = true
                            endif
                            break
                          endif
                        endfor
                      endif
                    endif
                  -%}
                  <li
                    id="Slide-{{ section.id }}-{{ featured_media.id }}"
                    class="teste product__media-item is-active flex-grid__item slider__slide{% if single_media_visible %} product__media-item--single{% endif %}{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.hide_variants and variant_images contains featured_media.src %} product__media-item--variant{% endif %}{% if gang_media_active == true %} gang__active{% endif %}"
                    data-media-id="{{ section.id }}-{{ featured_media.id }}"
                    data-media-position="{{ gallery_index }}"
                    {% if gang_exist == true %}
                      data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                    {% endif %}
                  >
                    {% render 'product-v3-image',
                      media: featured_media,
                      position: 'featured',
                      zoom: section.settings.enable_image_zoom,
                      loop: section.settings.enable_video_looping,
                      modal_id: section.id,
                      xr_button: true,
                      media_width: media_width,
                      image_ratio: image_ratio,
                      mobile_image_ratio: mobile_image_ratio,
                      lazy_load: false
                    %}
                  </li>
                {%- endif -%}
                {%- assign matching_media_count = 0 -%}
                {%- for media in product.media -%}
                  {% if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true %}
                    {% assign v_title = product.selected_or_first_available_variant.title
                      | downcase
                      | replace: ' ', ''
                    %}
                    {% assign media_alt = media.alt | downcase | replace: ' ', '' %}
                  {% else %}
                    {% liquid
                      assign v_title = ''
                      assign media_alt = ''
                    %}
                  {% endif %}
                                    {%- assign media_matches = false -%}
                  {%- if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true -%}
                    {%- if media_alt == blank -%}
                      {%- assign media_matches = true -%}
                    {%- elsif v_title contains media_alt -%}
                      {%- assign media_matches = true -%}
                    {%- endif -%}
                  {%- else -%}
                    {%- assign media_matches = true -%}
                  {%- endif -%}

                  {%- if media_matches and media.id != featured_media.id -%}
            {%- assign matching_media_count = matching_media_count | plus: 1 -%}
            {%- assign gallery_index = gallery_index | plus: 1 -%}
                    {%- liquid
                      assign gang_option_name = ''
                      assign gang_media_active = false
                      assign gang_connect = ''
                      assign media_active = false

                      if featured_media_rendered == false and matching_media_count == 1
                        assign media_active = true
                      endif

                      if media.alt contains '#' and section.settings.hide_variants == false
                        assign gang_connect = media.alt | split: '#' | last
                        if gang_connect contains ':' and localization.language.iso_code != blank
                          assign gang_connect = gang_connect | append: ','
                          assign split_param = localization.language.iso_code | append: ':'
                          assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                        endif
                        if gang_connect contains '_'
                          assign gang_exist = true
                          assign gang_option_name = gang_connect | split: '_' | first | handleize
                          assign media_active = false

                          for option in product.options_with_values
                            assign option_name_handlized = option.name | handleize | replace: '_', '-'
                            if option_name_handlized == gang_option_name
                              assign current_option_value = option.selected_value | handleize
                              assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                              if gang_connect == current_connect
                                assign gang_media_active = true
                                assign media_active = true
                              endif
                              break
                            endif
                          endfor
                        endif
                      endif
                    -%}
                    <li
                      id="Slide-{{ section.id }}-{{ media.id }}"
                      class="teste2 product__media-item flex-grid__item slider__slide{% if single_media_visible %} product__media-item--single{% endif %}{% if media_active == true %} is-active{% endif %}{% if media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.hide_variants and variant_images contains media.src %} product__media-item--variant{% endif %}{% if gang_media_active == true %} gang__active{% endif %}"
                      data-media-id="{{ section.id }}-{{ media.id }}"
                      data-media-position="{{ gallery_index }}"
                      {% if gang_exist == true %}
                        data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                      {% endif %}
                    >
                      {% render 'product-v3-image',
                        media: media,
                        position: forloop.index,
                        zoom: section.settings.enable_image_zoom,
                        loop: section.settings.enable_video_looping,
                        modal_id: section.id,
                        xr_button: true,
                        media_width: media_width,
                        image_ratio: image_ratio,
                        mobile_image_ratio: mobile_image_ratio
                      %}
                    </li>
                  {%- endif -%}
                {%- endfor -%}

                {%- for media in product.media -%}
          {% assign media_alt = media.alt | downcase | replace: ' ', '' %}
          {%- if media_alt == 'all' -%}
            {%- assign gallery_index = gallery_index | plus: 1 -%}
            <li
              id="Slide-all-{{ section.id }}-{{ media.id }}"
              class="product__media-item flex-grid__item slider__slide{% if media.media_type != 'image' %} product__media-item--full{% endif %}"
              data-media-id="{{ section.id }}-{{ media.id }}"
              data-media-position="{{ gallery_index }}"
            >
                      {% render 'product-image',
                        media: media,
                        position: forloop.index,
                        zoom: section.settings.enable_image_zoom,
                        loop: section.settings.enable_video_looping,
                        modal_id: section.id,
                        xr_button: true,
                        media_width: media_width,
                        image_ratio: image_ratio,
                        mobile_image_ratio: mobile_image_ratio
                      %}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
              <div class="slider-buttons no-js-hidden{% if media_count < 2 or section.settings.show_mobile_thumbnails %} small-hide{% endif %}">
                <div class="slider-counter caption">
                  <span class="slider-counter--current">1</span>
                  <span aria-hidden="true"> / </span>
                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                  <span class="slider-counter--total">{{ media_count }}</span>
                </div>
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false">
                    <path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path>
                  </svg>
                </button>
                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false">
                    <path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path>
                  </svg>
                </button>
              </div>

              {%- if section.settings.enable_image_zoom -%}
                <div class="gallery-cursor">
                  <span class="icon icon-plus-alt"></span>
                </div>
              {%- endif -%}

              {% for block in section.blocks %}
                {% if block.type == 'iwt_gallery' %}
                  {%- comment -%}
                    CWV FIX (C9): os width/height attributes antes refletiam o
                    tamanho ORIGINAL do upload (ex: 512x512), mas a imagem era
                    escalada para `icon1_size` px via inline style — o intrinsic
                    ratio ainda batia (1:1) mas a reserva de espaço usava as
                    medidas grandes, causando shift no primeiro paint + cache
                    miss em Lighthouse. Agora usamos a dimensão de display real
                    como attribute e confiamos no aspect-ratio preservado.
                  {%- endcomment -%}
                  {%- assign icon1_ratio = block.settings.icon1.aspect_ratio | default: 1 -%}
                  {%- assign icon1_w = icon1_ratio | times: block.settings.icon1_size | round: 0 -%}
                  {%- assign icon2_ratio = block.settings.icon2.aspect_ratio | default: 1 -%}
                  {%- assign icon2_w = icon2_ratio | times: block.settings.icon2_size | round: 0 -%}
                  <div class="iwt-gallery-wr">
                    <div class="iwt-gallery-item" style="box-sizing: border-box; height: 30px; padding: {{ block.settings.item1_padding_y }}px 0.7rem {{ block.settings.item1_padding_y }}px {{ block.settings.item1_padding_x }}px;">
                      {% if block.settings.icon1 != blank %}
                        <img
                          src="{{ block.settings.icon1 | image_url: width: icon1_w }}"
                          width="{{ icon1_w }}"
                          height="{{ block.settings.icon1_size }}"
                          alt="{{ block.settings.text1 }} Icon"
                          loading="lazy"
                          decoding="async"
                        >
                      {% endif %}
                      <span class="icon-text">{{ block.settings.text1 }}</span>
                    </div>
                    <div class="iwt-gallery-item" style="box-sizing: border-box; height: 30px; padding: {{ block.settings.item2_padding_y }}px 0.7rem {{ block.settings.item2_padding_y }}px {{ block.settings.item2_padding_x }}px;">
                      {% if block.settings.icon2 != blank %}
                        <img
                          src="{{ block.settings.icon2 | image_url: width: icon2_w }}"
                          width="{{ icon2_w }}"
                          height="{{ block.settings.icon2_size }}"
                          alt="{{ block.settings.text2 }} Icon"
                          loading="lazy"
                          decoding="async"
                        >
                      {% endif %}
                      <span class="icon-text">{{ block.settings.text2 }}</span>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}

            </product-gallery>
          </use-animate>
          {%- if first_3d_model -%}
            <button
              class="button button--full-width product__xr-button"
              type="button"
              aria-label="{{ 'products.product.xr_button_label' | t }}"
              data-shopify-xr
              data-shopify-model3d-id="{{ first_3d_model.id }}"
              data-shopify-title="{{ product.title | escape }}"
              data-shopify-xr-hidden
            >
              {% render 'icon', icon: '3d-model' %}
              {{ 'products.product.xr_button' | t }}
            </button>
          {%- endif -%}

          {%- liquid
  assign show_desktop_thumbnails = false
  if section.settings.gallery_layout == 'thumbnail_slider' or section.settings.gallery_layout == 'vertical_slider'
    assign show_desktop_thumbnails = true
  endif
-%}

{%- if product.media.size > 1 and show_desktop_thumbnails or section.settings.show_mobile_thumbnails -%}
            <thumbnail-slider
              id="GalleryThumbnails-{{ section.id }}"
              class="{% if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true %}product-thumbnails-d5 {% endif %}thumbnail-slider slider-mobile-gutter{% unless section.settings.show_mobile_thumbnails %} small-hide{% endunless %}{% if media_count <= 3 %} thumbnail-slider--no-slide{% endif %}"
            >
              <ul
                id="Slider-Thumbnails-{{ section.id }}"
                class="thumbnail-list list-unstyled slider slider--mobile{% if section.settings.gallery_layout == 'thumbnail_slider' or section.settings.gallery_layout == 'vertical_slider' %} slider--tablet-up{% endif %}"
                data-media-count="{{ product.media.size }}"
              >
                {%- if featured_media != blank and featured_media_matches -%}
                  {%- liquid
                    capture media_index
                      if featured_media.media_type == 'model'
                        increment model_index
                      elsif featured_media.media_type == 'video' or featured_media.media_type == 'external_video'
                        increment video_index
                      elsif featured_media.media_type == 'image'
                        increment image_index
                      endif
                    endcapture

                    assign media_index = media_index | plus: 1

                    assign gang_option_name = ''
                    assign gang_media_active = false
                    assign gang_connect = ''
                    if featured_media.alt contains '#' and section.settings.hide_variants == false
                      assign gang_connect = featured_media.alt | split: '#' | last
                      if gang_connect contains ':' and localization.language.iso_code != blank
                        assign gang_connect = gang_connect | append: ','
                        assign split_param = localization.language.iso_code | append: ':'
                        assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                      endif
                      if gang_connect contains '_'
                        assign gang_exist = true
                        assign gang_option_name = gang_connect | split: '_' | first | handleize

                        for option in product.options_with_values
                          assign option_name_handlized = option.name | handleize | replace: '_', '-'
                          if option_name_handlized == gang_option_name
                            assign current_option_value = option.selected_value | handleize
                            assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                            if gang_connect == current_connect
                              assign gang_media_active = true
                            endif
                            break
                          endif
                        endfor
                      endif
                    endif
                  -%}
                  <li
                    id="Slide-Thumbnails-{{ section.id }}-0"
                    class="thumbnail-list__item slider__slide{% if section.settings.hide_variants and variant_images contains featured_media.src %} thumbnail-list_item--variant{% endif %} is-active media-wrapper media-wrapper--small{% if gang_media_active == true %} gang__active{% endif %}"
                    data-target="{{ section.id }}-{{ featured_media.id }}"
                    data-media-position="{{ media_index }}"
                    data-media-id="thumbnail--{{ section.id }}-{{ featured_media.id }}"
                    {% if gang_exist == true %}
                      data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                    {% endif %}
                  >
                    <button
                      class="thumbnail media media--square"
                      aria-label="{%- if featured_media.media_type == 'image' -%}{{ 'products.product.media.load_image' | t: index: media_index }}{%- elsif featured_media.media_type == 'model' -%}{{ 'products.product.media.load_model' | t: index: media_index }}{%- elsif featured_media.media_type == 'video' or featured_media.media_type == 'external_video' -%}{{ 'products.product.media.load_video' | t: index: media_index }}{%- endif -%}"
                      aria-current="true"
                      aria-controls="GalleryViewer-{{ section.id }}"
                      aria-describedby="Thumbnail-{{ section.id }}-0"
                    >
                      {%- capture sizes -%}(min-width: {{ settings.page_width }}px) calc(({{ settings.page_width | minus: 100 | times: media_width | round }} - 4rem) / 4), (min-width: 990px) calc(({{ media_width | times: 100 }}vw - 4rem) / 4), (min-width: 750px) calc((100vw - 15rem) / 8), calc((100vw - 14rem) / 3){%- endcapture -%}
                      {%- liquid
                        assign image_id = 'Thumbnail-' | append: section.id | append: '-0'
                        assign alt = featured_media.alt | escape | split: '#' | first
                        comment
                          CWV FIX (CLS): passar `width`/`height` explícitos ao image_tag
                          para evitar "Unsized image element". Neste tema, image_tag
                          requer image_url como input e não emite width/height
                          automaticamente — precisam vir como params.
                        endcomment
                        echo featured_media.preview_image | image_url: width: 416 | image_tag: loading: 'eager', id: image_id, sizes: sizes, widths: '54, 74, 162, 208, 324, 416', width: featured_media.preview_image.width, height: featured_media.preview_image.height, alt: alt
                      -%}
                    </button>
                  </li>
                {%- endif -%}
                {%- assign matching_media_count = 0 -%}
                {%- for media in product.media -%}
                  {% if section.settings.enable_variant_specific_media or product.metafields.custom.variant_specific_media.value == true %}
                    {% assign v_title = product.selected_or_first_available_variant.title
                      | downcase
                      | replace: ' ', ''
                    %}
                    {% assign media_alt = media.alt | downcase | replace: ' ', '' %}
                  {% else %}
                    {% liquid
                      assign v_title = ''
                      assign media_alt = ''
                    %}
                  {% endif %}
                  {%- if v_title contains media_alt and media.id != featured_media.id -%}
                    {%- liquid
                      capture media_index
                        if media.media_type == 'model'
                          increment model_index
                        elsif media.media_type == 'video' or media.media_type == 'external_video'
                          increment video_index
                        elsif media.media_type == 'image'
                          increment image_index
                        endif
                      endcapture

                      assign media_index = media_index | plus: 1

                      assign gang_option_name = ''
                      assign gang_media_active = false
                      assign gang_connect = ''
                      assign media_active = false

                      if media.id == product.selected_or_first_available_variant.featured_media.id
                        assign media_active = true
                      endif

                      if media.alt contains '#' and section.settings.hide_variants == false
                        assign gang_connect = media.alt | split: '#' | last
                        if gang_connect contains ':' and localization.language.iso_code != blank
                          assign gang_connect = gang_connect | append: ','
                          assign split_param = localization.language.iso_code | append: ':'
                          assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                        endif
                        if gang_connect contains '_'
                          assign gang_exist = true
                          assign gang_option_name = gang_connect | split: '_' | first | handleize
                          assign media_active = false

                          for option in product.options_with_values
                            assign option_name_handlized = option.name | handleize | replace: '_', '-'
                            if option_name_handlized == gang_option_name
                              assign current_option_value = option.selected_value | handleize
                              assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                              if gang_connect == current_connect
                                assign gang_media_active = true
                                assign media_active = true
                              endif
                              break
                            endif
                          endfor
                        endif
                      endif
                    -%}
                    <li
                      id="Slide-Thumbnails-{{ section.id }}-{{ forloop.index }}"
                      class="thumbnail-list__item slider__slide{% if section.settings.hide_variants and variant_images contains media.src %} thumbnail-list_item--variant{% endif %}{% if media_active == true %} is-active{% endif %} media-wrapper media-wrapper--small{% if gang_media_active == true %} gang__active{% endif %}"
                      data-target="{{ section.id }}-{{ media.id }}"
                      data-media-position="{{ media_index }}"
                      data-media-id="thumbnail--{{ section.id }}-{{ featured_media.id }}"
                      {% if gang_exist == true %}
                        data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                      {% endif %}
                    >
                      {%- if media.media_type != 'image' -%}
                        <span class="deferred-media__poster-button motion-reduce">
                          {%- if media.media_type == 'model' -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_model' | t }}</span>
                            {%- render 'icon', icon: '3d-model' -%}
                          {%- else -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_video' | t }}</span>
                            {%- render 'icon', icon: 'play' -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}

                      <button
                        class="thumbnail media media--square"
                        aria-label="{%- if media.media_type == 'image' -%}{{ 'products.product.media.load_image' | t: index: media_index }}{%- elsif media.media_type == 'model' -%}{{ 'products.product.media.load_model' | t: index: media_index }}{%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}{{ 'products.product.media.load_video' | t: index: media_index }}{%- endif -%}"
                        {% if media == featured_media or featured_media == null and forloop.first %}
                          aria-current="true"
                        {% endif %}
                        aria-controls="GalleryViewer-{{ section.id }}"
                        aria-describedby="Thumbnail-{{ section.id }}-{{ forloop.index }}"
                      >
                        {%- capture sizes -%}(min-width: {{ settings.page_width }}px) calc(({{ settings.page_width | minus: 100 | times: media_width | round }} - 4rem) / 4), (min-width: 990px) calc(({{ media_width | times: 100 }}vw - 4rem) / 4), (min-width: 750px) calc((100vw - 15rem) / 8), calc((100vw - 14rem) / 3){%- endcapture -%}
                        {%- liquid
                          assign image_id = 'Thumbnail-' | append: section.id | append: '-' | append: forloop.index
                          assign alt = media.alt | escape | split: '#' | first
                          comment
                            CWV FIX (CLS): `width`/`height` explícitos como params
                            do image_tag — ver explicação no thumbnail da featured_media.
                          endcomment
                          echo media.preview_image | image_url: width: 416 | image_tag: loading: 'eager', id: image_id, sizes: sizes, widths: '54, 74, 162, 208, 324, 416', width: media.preview_image.width, height: media.preview_image.height, alt: alt
                        -%}
                      </button>
                    </li>
                  {%- endif -%}
                {%- endfor -%}

                {%- for media in product.media -%}
                  {%- if media.alt == 'all' -%}
                    {%- liquid
                      capture media_index
                        if media.media_type == 'model'
                          increment model_index_all
                        elsif media.media_type == 'video' or media.media_type == 'external_video'
                          increment video_index_all
                        elsif media.media_type == 'image'
                          increment image_index_all
                        endif
                      endcapture

                      assign media_index = media_index | plus: 1
                    -%}
                    <li
                      id="Slide-Thumbnails-all-{{ section.id }}-{{ forloop.index }}"
                      class="thumbnail-list__item slider__slide media-wrapper media-wrapper--small"
                      data-target="{{ section.id }}-{{ media.id }}"
                      data-media-position="{{ media_index }}"
                      data-media-id="thumbnail--{{ section.id }}-{{ media.id }}"
                    >
                      {%- if media.media_type != 'image' -%}
                        <span class="deferred-media__poster-button motion-reduce">
                          {%- if media.media_type == 'model' -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_model' | t }}</span>
                            {%- render 'icon', icon: '3d-model' -%}
                          {%- else -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_video' | t }}</span>
                            {%- render 'icon', icon: 'play' -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}

                      <button
                        class="thumbnail media media--square"
                        aria-label="{%- if media.media_type == 'image' -%}{{ 'products.product.media.load_image' | t: index: media_index }}{%- elsif media.media_type == 'model' -%}{{ 'products.product.media.load_model' | t: index: media_index }}{%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}{{ 'products.product.media.load_video' | t: index: media_index }}{%- endif -%}"
                        aria-controls="GalleryViewer-{{ section.id }}"
                        aria-describedby="Thumbnail-all-{{ section.id }}-{{ forloop.index }}"
                      >
                        {%- capture sizes -%}(min-width: {{ settings.page_width }}px) calc(({{ settings.page_width | minus: 100 | times: media_width | round }} - 4rem) / 4), (min-width: 990px) calc(({{ media_width | times: 100 }}vw - 4rem) / 4), (min-width: 750px) calc((100vw - 15rem) / 8), calc((100vw - 14rem) / 3){%- endcapture -%}
                        {%- liquid
                          assign image_id = 'Thumbnail-all-' | append: section.id | append: '-' | append: forloop.index
                          assign alt = media.alt | escape | split: '#' | first
                          comment
                            CWV FIX (CLS): `width`/`height` explícitos como params
                            do image_tag — ver explicação no thumbnail da featured_media.
                          endcomment
                          echo media.preview_image | image_url: width: 416 | image_tag: loading: 'eager', id: image_id, sizes: sizes, widths: '54, 74, 162, 208, 324, 416', width: media.preview_image.width, height: media.preview_image.height, alt: alt
                        -%}
                      </button>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
              <div class="slider-buttons{% if media_count <= 3 %} small-hide{% endif %}{% if media_count <= 4 %} medium-hide large-up-hide{% endif %}">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                  aria-controls="GalleryThumbnails-{{ section.id }}"
                  data-step="3"
                >
                  {% render 'icon', icon: 'caret' %}
                </button>
                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                  aria-controls="GalleryThumbnails-{{ section.id }}"
                  data-step="3"
                >
                  {% render 'icon', icon: 'caret' %}
                </button>
              </div>
            </thumbnail-slider>
          {%- endif -%}

          {%- if section.settings.gallery_layout == 'stacked'
            and section.settings.show_thumbnails
            and product.media.size > 1
          -%}
            <div class="product__thumbnails-wrapper">
              <product-thumbnails id="ProductThumbnails-{{ section.id }}" class="product__thumbnails">
                {%- assign featured_thumb_rendered = false -%}
                {%- if featured_media != null and featured_media_matches -%}
                  {%- assign featured_thumb_rendered = true -%}
                  {%- liquid
                    if section.settings.hide_variants and variant_images contains featured_media.src
                      assign variant_image = true
                    else
                      assign variant_image = false
                    endif

                    assign gang_option_name = ''
                    assign gang_media_active = false
                    assign gang_connect = ''
                    if featured_media.alt contains '#' and section.settings.hide_variants == false
                      assign gang_connect = featured_media.alt | split: '#' | last
                      if gang_connect contains ':' and localization.language.iso_code != blank
                        assign gang_connect = gang_connect | append: ','
                        assign split_param = localization.language.iso_code | append: ':'
                        assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                      endif
                      if gang_connect contains '_'
                        assign gang_exist = true
                        assign gang_option_name = gang_connect | split: '_' | first | handleize

                        for option in product.options_with_values
                          assign option_name_handlized = option.name | handleize | replace: '_', '-'
                          if option_name_handlized == gang_option_name
                            assign current_option_value = option.selected_value | handleize
                            assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                            if gang_connect == current_connect
                              assign gang_media_active = true
                            endif
                            break
                          endif
                        endfor
                      endif
                    endif
                  -%}
                  <div
                    data-section="{{ section.id }}"
                    data-media-id="{{ featured_media.id }}"
                    class="product__thumbnail media-wrapper media-wrapper--small{% if variant_image %} product__media-item--variant{% endif %} is-active {% if gang_media_active == true %} gang__active{% endif %}"
                    data-thumbnail-position="{{ featured_media.position }}"
                    {% if gang_exist == true %}
                      data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                    {% endif %}
                  >
                    <div
                      class="media media--adapt"
                      style="--image-ratio-percent: {{ 1 | divided_by: featured_media.preview_image.aspect_ratio | times: 100 }}%;"
                    >
                      <img
                        srcset="{{ featured_media.preview_image | image_url: width: 165 }} 1x, {{ featured_media.preview_image | image_url: width: 330 }} 2x"
                        src="{{ featured_media.preview_image | image_url: width: 165 }}"
                        loading="eager"
                        width="{{ featured_media.preview_image.width }}"
                        height="{{ featured_media.preview_image.height }}"
                        alt="{{ featured_media.preview_image.alt | escape | split: '#' | first }}"
                        is="lazy-image"
                      >
                    </div>
                    {%- if featured_media.media_type != 'image' -%}
                      <span class="deferred-media__poster-button motion-reduce">
                        {%- if featured_media.media_type == 'model' -%}
                          <span class="visually-hidden">{{ 'products.product.media.play_model' | t }}</span>
                          {%- render 'icon', icon: '3d-model' -%}
                        {%- else -%}
                          <span class="visually-hidden">{{ 'products.product.media.play_video' | t }}</span>
                          {%- render 'icon', icon: 'play' -%}
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- for media in product.media -%}
                  {%- unless media.id == featured_media.id -%}
                    {%- liquid
                      if section.settings.hide_variants and variant_images contains media.src
                        assign variant_image = true
                      else
                        assign variant_image = false
                      endif

                      assign gang_option_name = ''
                      assign gang_media_active = false
                      assign gang_connect = ''
                      assign media_active = false

                      if media == featured_media or featured_media == null and forloop.first
                        assign media_active = true
                      endif

                      if media.alt contains '#' and section.settings.hide_variants == false
                        assign gang_connect = media.alt | split: '#' | last
                        if gang_connect contains ':' and localization.language.iso_code != blank
                          assign gang_connect = gang_connect | append: ','
                          assign split_param = localization.language.iso_code | append: ':'
                          assign gang_connect = gang_connect | split: split_param | last | split: ',' | first
                        endif
                        if gang_connect contains '_'
                          assign gang_exist = true
                          assign gang_option_name = gang_connect | split: '_' | first | handleize
                          assign media_active = false

                          for option in product.options_with_values
                            assign option_name_handlized = option.name | handleize | replace: '_', '-'
                            if option_name_handlized == gang_option_name
                              assign current_option_value = option.selected_value | handleize
                              assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                              if gang_connect == current_connect
                                assign gang_media_active = true
                                assign media_active = true
                              endif
                              break
                            endif
                          endfor
                        endif
                      endif
                    -%}
                    <div
                      data-section="{{ section.id }}"
                      data-media-id="{{ media.id }}"
                      class="product__thumbnail media-wrapper media-wrapper--small{% if variant_image %} product__media-item--variant{% endif %}{% if media_active == true %} is-active{% endif %}{% if gang_media_active == true %} gang__active{% endif %}"
                      data-thumbnail-position="{{ media.position }}"
                      {% if gang_exist == true %}
                        data-gang-option="{{ gang_option_name }}" data-gang-connect="{{ gang_connect }}"
                      {% endif %}
                    >
                      <div
                        class="media media--adapt"
                        style="--image-ratio-percent: {{ 1 | divided_by: media.preview_image.aspect_ratio | times: 100 }}%;"
                      >
                        <img
                          srcset="{{ media.preview_image | image_url: width: 165 }} 1x, {{ media.preview_image | image_url: width: 330 }} 2x"
                          src="{{ media.preview_image | image_url: width: 165 }}"
                          loading="eager"
                          width="{{ media.preview_image.width }}"
                          height="{{ media.preview_image.height }}"
                          alt="{{ media.preview_image.alt | escape | split: '#' | first }}"
                          is="lazy-image"
                        >
                      </div>
                      {%- if media.media_type != 'image' -%}
                        <span class="deferred-media__poster-button motion-reduce">
                          {%- if media.media_type == 'model' -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_model' | t }}</span>
                            {%- render 'icon', icon: '3d-model' -%}
                          {%- else -%}
                            <span class="visually-hidden">{{ 'products.product.media.play_video' | t }}</span>
                            {%- render 'icon', icon: 'play' -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}
                    </div>
                  {%- endunless -%}
                {%- endfor -%}
              </product-thumbnails>
            </div>
            <script src="{{ 'product-thumbnails.js' | asset_url }}" defer="defer"></script>
          {%- endif -%}
          {%- comment -%}
            CWV FIX (Forced Reflow + parser blocking): JS de navegação extraído
            para assets/product-v3-gallery-nav.js. Carregado com defer →
            roda depois do parse, não compete com o LCP.
            Atributo data-gallery-nav é o opt-in que o asset busca.
          {%- endcomment -%}
          <script src="{{ 'product-v3-gallery-nav.js' | asset_url }}" defer="defer"></script>
        </media-gallery>
