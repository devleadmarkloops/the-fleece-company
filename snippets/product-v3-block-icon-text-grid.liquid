{% comment %}
  Renders the icon_text_grid block (up to 4 icon+text items).

  Accepts:
  - block: {Object} Block object

  Mechanical extraction of the 'icon_text_grid' case from main-product-v2.liquid (lines 1488-1518).
{% endcomment %}

<div class="icon-text-grid-wrapper" {{ block.shopify_attributes }}>
  {%- for i in (1..4) -%}
    {%- capture current_icon -%}icon_{{ i }}{%- endcapture -%}
    {%- capture current_text -%}text_{{ i }}{%- endcapture -%}

    {%- assign icon_img = block.settings[current_icon] -%}
    {%- assign icon_text = block.settings[current_text] -%}

    {%- if icon_img != blank or icon_text != blank -%}
      <div
        class="icon-text-wr"
        style="--icon-size: {{ block.settings.icon_size }}px; --icon-size-mob: {{ block.settings.icon_size_mob }}px; margin-bottom: 0;"
      >
        {% comment %}
          CWV FIX (CLS): mesmo tratamento aplicado em product-v3-block-icon-text.liquid
          — reservamos largura/altura no tamanho final (icon_size) para que o CSS
          assíncrono (`.icon-text-wr img{width:var(--icon-size)}`) não colapse o
          intrínseco 512×512 depois do primeiro paint.
        {% endcomment %}
        {% if icon_img != blank %}
          {%- assign cwv_gicon_ar = icon_img.aspect_ratio | default: 1.0 -%}
          {%- assign cwv_gicon_w = block.settings.icon_size | default: 30 -%}
          {%- assign cwv_gicon_h = cwv_gicon_w | times: 1.0 | divided_by: cwv_gicon_ar | round: 0 -%}
          {%- if cwv_gicon_h < 1 -%}{%- assign cwv_gicon_h = cwv_gicon_w -%}{%- endif -%}
          {%- assign cwv_gicon_src_w = cwv_gicon_w | times: 2 -%}
          <img
            src="{{ icon_img | image_url: width: cwv_gicon_src_w }}"
            width="{{ cwv_gicon_w }}"
            height="{{ cwv_gicon_h }}"
            alt="{{ icon_img.alt | escape | default: 'Icon' }}"
            loading="lazy"
            decoding="async"
          >
        {% endif %}

        {% if icon_text != blank %}
          <span
            class="icon-text"
            style="--text-size: {{ block.settings.text_size }}px; --text-size-mob: {{ block.settings.text_size_mob }}px; --text-color: {{ block.settings.text_color }};"
          >
            {{ icon_text }}
          </span>
        {% endif %}
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>
