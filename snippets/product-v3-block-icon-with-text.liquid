{% comment %}
  Renders the icon_with_text block (3 items).

  Accepts:
  - block: {Object} Block object

  Mechanical extraction of the 'icon_with_text' case from main-product-v2.liquid (lines 1798-1825).
{% endcomment %}

<div class="icon-text-container" {{ block.shopify_attributes }}>
  <div class="icon-text-grid">
    {%- for i in (1..3) -%}
      {%- capture icon_setting -%}icon_{{ i }}{%- endcapture -%}
      {%- capture text_setting -%}text_{{ i }}{%- endcapture -%}

      {%- if block.settings[icon_setting] != blank or block.settings[text_setting] != blank -%}
        <div class="icon-text-item">
          {%- if block.settings[icon_setting] != blank -%}
            <div class="icon-text-image">
              <img
                src="{{ block.settings[icon_setting] | image_url: width: 80 }}"
                alt="{{ block.settings[icon_setting].alt }}"
                loading="eager"
                width="48"
                height="48"
              >
            </div>
          {%- endif -%}
          {%- if block.settings[text_setting] != blank -%}
            <p class="icon-text-label">{{ block.settings[text_setting] }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
