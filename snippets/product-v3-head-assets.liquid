  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    {%- liquid
      comment if product.metafields.custom.featured_image_as_default
      assign featured_media = product.media.first
      else
      assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
      endif
      endcomment

      assign first_image = featured_media | default: product.media.first

      assign first_image_ratio = 1 | divided_by: first_image.aspect_ratio | times: 100
    -%}


    #Slider-Gallery-{{ section.id }} {
      /* --force-image-ratio-percent: {{ first_image_ratio }}%; */
    }

    /* CWV FIX (C1): manter padding-bottom% como fallback; navegadores
       modernos (>=95% de share) usam aspect-ratio nativo, que reserva o
       mesmo espaço sem depender do hack de container + abs-positioned
       child. Isso reduz recálculo de layout e elimina CLS causado por
       subpixel rounding. */
    @media screen and (max-width: 749px) {
      #Slider-Gallery-{{ section.id }} .media-mobile--adapt_first {
        padding-bottom: {{ first_image_ratio }}%;
      }
    }

    @media screen and (min-width: 750px) {
      .product--thumbnail_slider #Slider-Gallery-{{ section.id }} .media--adapt_first,
      .product--columns #Slider-Gallery-{{ section.id }} .media--adapt_first {
        padding-bottom: {{ first_image_ratio }}%;
      }
    }

    @supports (aspect-ratio: 1 / 1) {
      @media screen and (max-width: 749px) {
        #Slider-Gallery-{{ section.id }} .media-mobile--adapt_first {
          padding-bottom: 0;
          aspect-ratio: {{ first_image.aspect_ratio | default: 1 }};
        }
      }

      @media screen and (min-width: 750px) {
        .product--thumbnail_slider #Slider-Gallery-{{ section.id }} .media--adapt_first,
        .product--columns #Slider-Gallery-{{ section.id }} .media--adapt_first {
          padding-bottom: 0;
          aspect-ratio: {{ first_image.aspect_ratio | default: 1 }};
        }
      }
    }
  {%- endstyle -%}

