{% comment %}
  Renders the pairs_well block (swiper of pair-able products with variant swatches).

  Accepts:
  - block:   {Object} Block object
  - product: {Object} Product object (for call consistency)

  Mechanical extraction of the 'pairs_well' case from main-product-v2.liquid (lines 2432-2581).
{% endcomment %}

<div class="pairs-well-block" {{ block.shopify_attributes }}>
  <div class="pairs-well-header">
    <h3 class="h4">{{ block.settings.heading }}</h3>
    {%- if block.settings.product_list.count > 1 -%}
      {% comment %} <div class="pairs-well-nav">
        <div class="swiper-button-prev pw-prev-{{ block.id }}"></div>
        <div class="swiper-button-next pw-next-{{ block.id }}"></div>
      </div> {% endcomment %}
    {%- endif -%}
  </div>

  <div class="swiper pairs-well-swiper-{{ block.id }}">
    <div class="swiper-wrapper">
      {%- for product in block.settings.product_list -%}
        <div class="swiper-slide">
          {% render 'card-pairs-well', card_product: product %}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <script>
    window.SwiperReady(function() {
      new Swiper('.pairs-well-swiper-{{ block.id }}', {
        slidesPerView: 1,
        spaceBetween: 10,
        autoHeight: true,
        navigation: {
          nextEl: '.pw-next-{{ block.id }}',
          prevEl: '.pw-prev-{{ block.id }}',
        },
        breakpoints: {
          768: { slidesPerView: 1 },
          990: { slidesPerView: 1 }
        }
      });

      const blockContainer = document.querySelector('.pairs-well-swiper-{{ block.id }}').closest('.pairs-well-block');

      if (blockContainer) {
        // 1. Handle Custom Dropdown Clicks (Opens dropdown & selects swatches)
        blockContainer.addEventListener('click', function(e) {
          // Toggle Open/Close
          const trigger = e.target.closest('.pw-swatch-trigger');
          if (trigger) {
            const dropdown = trigger.closest('.pw-custom-swatch-dropdown');
            dropdown.classList.toggle('is-open');
            return;
          }

          // Select a Color Swatch
          const swatchItem = e.target.closest('.pw-swatch-item');
          if (swatchItem) {
            const dropdown = swatchItem.closest('.pw-custom-swatch-dropdown');
            const value = swatchItem.getAttribute('data-value');
            const bg = swatchItem.getAttribute('data-swatch-bg');

            // Update Visuals
            dropdown.querySelectorAll('.pw-swatch-item').forEach(item => item.classList.remove('is-selected'));
            swatchItem.classList.add('is-selected');
            dropdown.querySelector('.selected-swatch-indicator').style.background = bg;
            dropdown.querySelector('.selected-swatch-indicator').style.backgroundSize = 'cover';
            dropdown.querySelector('.selected-swatch-indicator').style.backgroundPosition = 'center';

            // Update Hidden Select & Trigger Change
            const hiddenSelect = dropdown.nextElementSibling;
            hiddenSelect.value = value;
            dropdown.classList.remove('is-open');

            // Dispatch event so the rest of the logic fires
            hiddenSelect.dispatchEvent(new Event('change', { bubbles: true }));
            return;
          }

          // Close dropdown if clicked outside
          if (!e.target.closest('.pw-custom-swatch-dropdown')) {
            blockContainer.querySelectorAll('.pw-custom-swatch-dropdown.is-open').forEach(dd => {
              dd.classList.remove('is-open');
            });
          }
        });

        // 2. Handle Variant Matching (Updates Price, Image, Add to Cart)
        blockContainer.addEventListener('change', function(e) {
          if (e.target.matches('.pairs-well-select')) {

            const card = e.target.closest('.pairs-well-card');
            const allSelects = card.querySelectorAll('.pairs-well-select');
            const currentOptions = Array.from(allSelects).map(sel => sel.value);

            const jsonScript = card.querySelector('.pairs-well-variant-json');
            if (!jsonScript) return;
            const variants = JSON.parse(jsonScript.innerHTML);

            const match = variants.find(variant => {
              return variant.options.every((opt, index) => opt === currentOptions[index]);
            });

            const btn = card.querySelector('.pairs-well-btn');
            const img = card.querySelector('.pairs-well-img');
            const inputId = card.querySelector('.pairs-well-final-id');
            const regularPriceEl = card.querySelector('.pw-regular-price');
            const comparePriceEl = card.querySelector('.pw-compare-price');

            if (match) {
              inputId.value = match.id;

              if (match.featured_image) {
                img.src = match.featured_image;
              }

              if (regularPriceEl && comparePriceEl) {
                if (match.compare_at_price) {
                  regularPriceEl.innerHTML = match.price;
                  regularPriceEl.classList.add('price-item--sale');
                  regularPriceEl.classList.remove('price-item--regular');

                  comparePriceEl.innerHTML = match.compare_at_price;
                  comparePriceEl.style.display = 'inline-block';
                } else {
                  regularPriceEl.innerHTML = match.price;
                  regularPriceEl.classList.remove('price-item--sale');
                  regularPriceEl.classList.add('price-item--regular');

                  comparePriceEl.style.display = 'none';
                }
              }

              if (match.available) {
                btn.textContent = "Add";
                btn.disabled = false;
                btn.classList.remove('disabled');
              } else {
                btn.textContent = "{{ 'products.product.sold_out' | t }}";
                btn.disabled = true;
                btn.classList.add('disabled');
              }
            } else {
              btn.textContent = "{{ 'products.product.unavailable' | t }}";
              btn.disabled = true;
              btn.classList.add('disabled');
            }
          }
        });
      }
    });
  </script>
</div>
